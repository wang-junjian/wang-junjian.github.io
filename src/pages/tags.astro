---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getAllTags } from '../utils/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import TaxonomyPage from '../components/TaxonomyPage.astro';

const posts = await getCollection('posts');
const tags = getAllTags(posts);
const sortedTags = Array.from(tags.entries()).sort((a, b) => b[1].length - a[1].length);

const postsByYear = new Map<number, number>();
for (const post of posts) {
  const year = post.data.date ? new Date(post.data.date).getFullYear() : 0;
  if (year > 0) {
    postsByYear.set(year, (postsByYear.get(year) || 0) + 1);
  }
}
const years = Array.from(postsByYear.entries()).sort((a, b) => b[0] - a[0]);
---

<BaseLayout
  title={`标签 - ${SITE_TITLE}`}
  description={`浏览 ${SITE_TITLE} 的文章标签。${SITE_DESCRIPTION}`}
  canonical={Astro.url.toString()}
>
  <TaxonomyPage
    taxonomyType="tag"
    items={sortedTags}
    totalPosts={posts.length}
    labelSingular="标签"
    labelPlural="标签"
    years={years}
  />
</BaseLayout>
