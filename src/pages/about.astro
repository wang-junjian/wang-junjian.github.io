---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title={`关于 | ${SITE_TITLE}`}>
  <PageHeader
    title="关于"
    backHref="/"
    backLabel="返回首页"
    maxWidth="max-w-content"
  />

  <section class="py-16 px-8">
    <div class="max-w-content mx-auto">
      <div class="prose animate-fade-in-up" style="animation-delay: 0.1s;">
        <p>欢迎来到军舰日志！</p>

        <p>这是一个务实程序员的技术博客，专注于分享编程、系统管理、人工智能等领域的知识和经验。</p>

        <h2>联系方式</h2>
        <ul>
          <li>GitHub: <a href="https://github.com/wang-junjian">wang-junjian</a></li>
          <li>Email: wang-junjian@qq.com</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
