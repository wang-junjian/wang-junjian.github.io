---
import '../styles/ai-chat.css';
---

<div class="ai-chat-widget" id="aiChatWidget" data-turbo-permanent>
  <button class="ai-chat-toggle" id="aiChatToggle" title="智能问答">🤖</button>
  <div class="ai-chat-window" id="aiChatWindow">
    <div class="ai-chat-header">
      <div class="ai-chat-header-left">
        <span class="ai-chat-avatar">🤖</span>
        <div>
          <p class="ai-chat-title">智能问答助手</p>
        </div>
      </div>
      <div class="ai-chat-header-actions">
        <button class="ai-chat-header-btn" id="aiChatModeToggle" title="切换布局">⇄</button>
        <button class="ai-chat-header-btn" id="aiChatClear" title="清空聊天记录">🗑️</button>
        <button class="ai-chat-header-btn" id="aiChatConfig" title="配置">⚙️</button>
        <button class="ai-chat-header-btn" id="aiChatClose" title="关闭">✕</button>
      </div>
    </div>
    <div class="ai-chat-status" id="aiChatStatus">⏳ 初始化...</div>
    <div class="ai-chat-config" id="aiChatConfigPanel">
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">Ollama Base URL</label>
        <input type="text" class="ai-chat-config-input" id="ollamaBaseUrlInput" placeholder="http://localhost:11434/v1" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">Ollama Embedding Model</label>
        <input type="text" class="ai-chat-config-input" id="ollamaEmbeddingModelInput" placeholder="bge-m3:latest" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM Base URL</label>
        <input type="text" class="ai-chat-config-input" id="apiBaseUrlInput" placeholder="https://api.openai.com/v1" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM API Key</label>
        <input type="password" class="ai-chat-config-input" id="apiKeyInput" placeholder="sk-..." />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM Chat Model</label>
        <input type="text" class="ai-chat-config-input" id="chatModelInput" placeholder="gpt-4o-mini" />
      </div>
      <button class="ai-chat-save-btn" id="saveApiConfig">保存配置</button>
      <div class="ai-chat-config-group" style="margin-top: 12px;">
        <label class="ai-chat-config-label">日志级别</label>
        <select class="ai-chat-config-input" id="logLevelInput" style="cursor: pointer;">
          <option value="debug">Debug (最详细)</option>
          <option value="info" selected>Info (推荐)</option>
          <option value="warn">Warn</option>
          <option value="error">Error</option>
        </select>
      </div>
      <button class="ai-chat-save-btn" id="exportLogsBtn" style="margin-top: 6px;">导出日志</button>
      <p class="ai-chat-config-note">💡 配置和聊天记录仅保存在本地浏览器中</p>
    </div>
    <div class="ai-chat-messages" id="aiChatMessages"></div>
    <div class="ai-chat-input-area">
      <div class="ai-chat-input-wrapper">
        <textarea class="ai-chat-input" id="aiChatInput" placeholder="输入你的问题..." rows="1" disabled></textarea>
        <button class="ai-chat-send-btn" id="aiChatSend" disabled>发送</button>
      </div>
      <div class="quick-questions" id="quickQuestions">
        <button class="quick-question-btn" data-question="作为人工智能的技术专家，将本文档转化为易于理解的摘要。">总结本文档的核心内容</button>
        <button class="quick-question-btn" data-question="OpenClaw 的架构设计">OpenClaw 的架构设计</button>
        <button class="quick-question-btn" data-question="智能体的工作原理">智能体的工作流程</button>
      </div>
    </div>
  </div>
</div>

<script src="../scripts/aichat.ts"></script>
