---
interface Props {
  backHref?: string;
  backLabel?: string;
  closingText?: string;
}

const { backHref = '/', backLabel = '返回首页', closingText = '感谢阅读' } = Astro.props;
---

<footer class="max-w-content mx-auto pt-12 px-8 pb-20 border-t border-[var(--border)]">
  <div class="flex justify-between items-center gap-8 flex-wrap">
    <a href={backHref} class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] text-[var(--text-primary)] no-underline text-sm font-medium tracking-[0.05em] uppercase transition-all duration-200 bg-white hover:border-[var(--text-primary)] hover:-translate-y-0.5">
      <span>←</span>
      {backLabel}
    </a>
    <div class="text-sm text-[var(--text-secondary)]">
      {closingText}
    </div>
  </div>
</footer>
