---
import { formatDate } from '../utils/posts';

function formatISODate(date: Date | string | undefined): string {
  if (!date) return '';
  const d = typeof date === 'string' ? new Date(date) : date;
  if (isNaN(d.getTime())) return '';
  return d.toISOString().split('T')[0];
}

interface Props {
  totalPosts: number;
  recentTags?: Array<[string, number]>;
  highlights?: Array<{ id: string; title: string; date: Date | string }>;
}

const { totalPosts, recentTags = [], highlights = [] } = Astro.props;

const firstYear = 2018; // Approximate start year; can be made dynamic later
---

<aside class="stream-sidebar">
  {highlights.length > 0 && (
    <div class="sidebar-section">
      <h3>精选内容</h3>
      <ul class="sidebar-highlights">
        {highlights.map((post) => (
          <li>
            <a href={`/posts/${post.id}`} class="sidebar-highlight-link">
              <span class="sidebar-highlight-title">{post.title || post.id}</span>
              <time class="sidebar-highlight-date" datetime={formatISODate(post.date)}>
                {formatISODate(post.date)}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {recentTags.length > 0 && (
    <div class="sidebar-section">
      <h3>热门标签</h3>
      <div class="sidebar-tag-cloud">
        {recentTags.map(([tag, count]) => (
          <a href={`/tags#tag-${encodeURIComponent(tag)}`} class="sidebar-tag">
            {tag}
            <span class="sidebar-tag-count">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="sidebar-section">
    <h3>订阅</h3>
    <a href="/rss.xml" class="sidebar-link">RSS 订阅</a>
  </div>

  <div class="sidebar-section">
    <h3>统计</h3>
    <p class="sidebar-stat">
      <span id="postCount" class="sidebar-stat-number">{totalPosts.toLocaleString('zh-CN')}</span> 篇文章
    </p>
    <p class="sidebar-stat">
      始于 {firstYear} 年
    </p>
  </div>
</aside>
