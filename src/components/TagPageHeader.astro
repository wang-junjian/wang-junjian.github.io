---
interface Props {
  tag: string;
  postCount: number;
}

const { tag, postCount } = Astro.props;
---

<section class="pt-4 pb-2 px-8 bg-[var(--bg-primary)]">
  <div class="max-w-grid mx-auto">
    <h1 class="font-sans text-base font-semibold text-[var(--text-primary)]">
      {postCount.toLocaleString('zh-CN')} 篇文章带有标签 “{tag}”
    </h1>
  </div>
</section>
