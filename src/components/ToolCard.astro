---
interface Props {
  href: string;
  title: string;
  excerpt?: string;
  tags?: string[];
  date?: string;
  index?: number;
}

const { href, title, excerpt, tags = [], date, index = 0 } = Astro.props;

function formatDate(value: string | undefined): string | undefined {
  if (!value) return undefined;
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return value;
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

const formattedDate = formatDate(date);
---

<article
  class="tool-card group flex flex-col h-full rounded-xl border border-[var(--border)] bg-[var(--panel)] p-6 transition-all duration-200 hover:border-[var(--accent)] hover:shadow-lg"
  style={`animation-delay: ${(index % 8) * 0.05}s;`}
  data-title={title.toLowerCase()}
  data-excerpt={(excerpt || '').toLowerCase()}
  data-tags={tags.join(' ').toLowerCase()}
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-serif-display font-semibold text-xl leading-[1.3] tracking-[-0.02em] text-[var(--text-primary)]">
      {title}
    </h3>
    <span class="text-[var(--text-secondary)] opacity-0 transition-opacity duration-200 group-hover:opacity-100" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 7h10v10"/>
        <path d="M7 17 17 7"/>
      </svg>
    </span>
  </div>

  {excerpt && (
    <p class="text-[var(--text-secondary)] text-sm leading-relaxed mb-4 flex-1">
      {excerpt}
    </p>
  )}

  {(tags.length > 0 || formattedDate) && (
    <div class="flex flex-wrap items-center gap-3 mt-auto pt-4 border-t border-[var(--border)]">
      {formattedDate && (
        <span class="text-xs text-[var(--text-secondary)] tabular-nums">
          {formattedDate}
        </span>
      )}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-[var(--bg-primary)] text-[var(--text-secondary)] border border-[var(--border)]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  )}

  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="absolute inset-0 rounded-xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--accent)]"
    aria-label={`打开 ${title}`}
    data-turbo="false"
  >
  </a>
</article>

<style>
  .tool-card {
    position: relative;
    animation: fade-in-up 0.4s ease both;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
