---
import BackLink from './BackLink.astro';

interface Props {
  title: string;
  subtitle?: string;
  backHref?: string;
  backLabel?: string;
  maxWidth?: string;
  centered?: boolean;
}

const { title, subtitle, backHref, backLabel, maxWidth = 'max-w-grid', centered = false } = Astro.props;
---

<section class="py-16 px-8 bg-white border-b border-[var(--border)]">
  <div class={`${maxWidth} mx-auto ${centered ? 'text-center' : ''}`}>
    <h1 class="font-serif-display text-[3.5rem] font-semibold leading-[1.1] tracking-[-0.03em] mb-2 animate-fade-in-up">
      {title}
    </h1>
    {subtitle && (
      <p class="text-[var(--text-secondary)] text-lg animate-fade-in-up" style="animation-delay: 0.1s;">
        {subtitle}
      </p>
    )}
  </div>
</section>
