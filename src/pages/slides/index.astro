---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import { SITE_TITLE } from '../../consts';
import PostCard from '../../components/PostCard.astro';

const slidesDir = join(process.cwd(), 'slides');
const files = readdirSync(slidesDir)
  .filter((f) => f.endsWith('.md') && !f.startsWith('.'))
  .sort((a, b) => a.localeCompare(b));

const slides = files.map((file) => {
  const raw = readFileSync(join(slidesDir, file), 'utf-8');
  const titleMatch = raw.match(/^#\s+(.+)$/m);
  const title = titleMatch ? titleMatch[1].trim() : file.replace(/\.md$/, '');
  return { id: file.replace(/\.md$/, ''), title };
});
---

<BaseLayout title={`幻灯片 - ${SITE_TITLE}`}>
  <section class="pt-20 pb-12 px-8 bg-white border-b border-[var(--border)]">
    <div class="max-w-[800px] mx-auto text-center animate-fade-in-up">
      <h1 class="font-serif-display text-4xl font-semibold leading-[1.1] tracking-[-0.03em] text-[var(--text-primary)]">
        幻灯片
      </h1>
      <p class="text-[var(--text-secondary)] mt-4">
        人工智能技术分享
      </p>
    </div>
  </section>

  <section class="py-16 px-8">
    <div class="max-w-grid mx-auto">
      <div class="flex items-baseline justify-between mb-12">
        <h2 class="font-serif-display text-2xl font-semibold tracking-[-0.02em]">
          全部幻灯片
        </h2>
        <span class="text-[var(--text-secondary)] text-sm tabular-nums">
          {slides.length} 篇
        </span>
      </div>

      <div class="grid grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-12">
        {slides.map((slide, index) => (
          <PostCard
            href={`/slides/${encodeURIComponent(slide.id)}`}
            title={slide.title}
            linkText="查看幻灯片"
            showDate={false}
            index={index}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
