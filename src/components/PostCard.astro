---
interface Props {
  href: string;
  title: string;
  date?: string;
  excerpt?: string;
  linkText?: string;
  showDate?: boolean;
  index?: number;
}

const { href, title, date, excerpt, linkText = '阅读', showDate = true, index = 0 } = Astro.props;
---

<article
  class="post-item animate-fade-in-up flex flex-col gap-4 pb-8 border-b border-[var(--border)]"
  style={`animation-delay: ${(index % 6) * 0.1}s;`}
  data-title={title.toLowerCase()}
  data-excerpt={(excerpt || '').toLowerCase()}
>
  {showDate && date && (
    <time class="text-xs uppercase tracking-[0.08em] text-[var(--text-secondary)] font-medium">
      {date}
    </time>
  )}
  <h3 class="font-serif-display text-2xl font-semibold leading-[1.3] tracking-[-0.02em]">
    <a href={href} class="text-[var(--text-primary)] no-underline transition-colors duration-200 hover:text-[var(--accent)]">
      {title}
    </a>
  </h3>
  {excerpt && (
    <p class="text-[var(--text-secondary)] text-[0.95rem] leading-relaxed">
      {excerpt}
    </p>
  )}
  <a href={href} class="inline-flex items-center gap-2 text-[var(--text-primary)] no-underline text-sm font-medium mt-auto w-fit group">
    {linkText}
    <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
  </a>
</article>
