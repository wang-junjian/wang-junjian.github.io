---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { normalizeTags, getRelatedPosts, calculateReadingTime, generateExcerpt, getPostDisplayTitle } from '../../utils/posts';
import RelatedPosts from '../../components/RelatedPosts.astro';
import PostSidebar from '../../components/PostSidebar.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import PostJsonLd from '../../components/PostJsonLd.astro';
import PostContent from '../../components/PostContent.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const frontmatter = post.data;
const isQuote = frontmatter.type === 'quote';
const isLink = frontmatter.type === 'link';
const isRelease = frontmatter.type === 'release';
const isArticle = !isQuote && !isLink && !isRelease;
const readingTime = frontmatter.readTime !== false ? calculateReadingTime(post.body) : 0;

const tags = normalizeTags(frontmatter.tags);
const relatedPosts = getRelatedPosts(post, allPosts);

const pageTitle = getPostDisplayTitle(post);
const pageDescription = isArticle
  ? (frontmatter.excerpt || `${pageTitle} - ${SITE_DESCRIPTION}`)
  : (generateExcerpt(post.body, 200) || `${pageTitle} - ${SITE_DESCRIPTION}`);
const pageImage = frontmatter.image ? String(frontmatter.image) : undefined;
const postDate = frontmatter.date ? new Date(frontmatter.date) : new Date();
---

<BaseLayout
  title={`${pageTitle} - ${SITE_TITLE}`}
  description={pageDescription}
  image={pageImage}
  canonical={Astro.url.toString()}
  type="article"
  date={postDate}
  author="军舰"
  needsKatex={isArticle}
>
  <link rel="stylesheet" href="/styles/prose.css" />
  <PostJsonLd post={post} url={Astro.url} site={Astro.site} />

  <article>
    <section class="pt-6 pb-10 px-8">
      <div class="max-w-grid mx-auto flex flex-col lg:flex-row gap-8 lg:gap-12">
        {isArticle && (
          <div class="toc-wrapper print:hidden">
            <TableOfContents headings={headings} fixed={true} side="left" />
          </div>
        )}

        <div class="flex-1 min-w-0">
          <PostContent post={post} Content={Content} pageTitle={pageTitle} />

          <div class="giscus-container py-8">
            <script
              is:inline
              src="https://giscus.app/client.js"
              data-repo="wang-junjian/wang-junjian.github.io"
              data-repo-id="MDEwOlJlcG9zaXRvcnkzMDQxNzc5NjE="
              data-category="Comments"
              data-category-id="DIC_kwDOEiFjKc4C8psx"
              data-mapping="pathname"
              data-strict="0"
              data-reactions-enabled="1"
              data-emit-metadata="0"
              data-input-position="bottom"
              data-theme="preferred_color_scheme"
              data-lang="zh-CN"
              data-loading="eager"
              crossorigin="anonymous"
              async>
            </script>
          </div>

          <RelatedPosts posts={relatedPosts} />
        </div>

        <PostSidebar
          postId={post.id}
          date={frontmatter.date}
          readingTime={readingTime}
          tags={tags}
          class="print:hidden"
        />
      </div>
    </section>
  </article>

  <script src="../../scripts/post-scripts.ts"></script>
</BaseLayout>
