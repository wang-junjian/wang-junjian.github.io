---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { groupPostsByDay } from '../../utils/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import DayGroup from '../../components/DayGroup.astro';

const allPosts = await getCollection('posts');

const releases = allPosts
  .filter((post) => post.data.type === 'release')
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  });

const dayGroups = groupPostsByDay(releases);
const sortedDays = Array.from(dayGroups.keys()).sort((a, b) => b.localeCompare(a));
---

<BaseLayout
  title={`发布 - ${SITE_TITLE}`}
  description={`软件发布与版本更新。${SITE_DESCRIPTION}`}
  canonical={Astro.url.toString()}
  showChat={false}
  needsKatex={false}
>
  <section class="pt-10 pb-6 px-8">
    <div class="max-w-grid mx-auto">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        <!-- Main Stream -->
        <div class="flex-1 min-w-0">
          <div class="mb-8">
            <h1 class="font-serif-display text-[2rem] font-semibold tracking-[-0.02em] text-[var(--text-primary)]">
              发布
            </h1>
            <p class="mt-2 text-[var(--text-secondary)]">
              共 {releases.length} 条发布
            </p>
          </div>

          <div id="postsContainer" class="stream-container">
            {sortedDays.map((dayKey, dayIndex) => {
              const dayPosts = dayGroups.get(dayKey) || [];
              const entryStartIndex = sortedDays
                .slice(0, dayIndex)
                .reduce((acc, key) => acc + (dayGroups.get(key)?.length || 0), 0);
              return (
                <DayGroup
                  date={new Date(dayKey + 'T00:00:00')}
                  posts={dayPosts}
                  startIndex={entryStartIndex}
                />
              );
            })}
          </div>

          {releases.length === 0 && (
            <div class="text-center py-16 px-8">
              <p class="font-serif-display text-2xl text-[var(--text-secondary)]">
                暂无发布
              </p>
            </div>
          )}
        </div>

        <!-- Right Sidebar -->
        <aside class="w-full lg:w-72 flex-shrink-0">
          <div class="lg:sticky lg:top-24">
            <div class="p-6 border border-[var(--border)] rounded-lg">
              <h2 class="font-serif-display text-lg font-semibold mb-3 text-[var(--text-primary)]">
                关于发布
              </h2>
              <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
                这里记录软件项目的版本发布、Release Notes 和个人点评。
              </p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
