---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { groupPostsByDay, getAllTags, getPostDisplayTitle } from '../utils/posts';
import { paginate, PAGE_SIZE } from '../utils/pagination';
import { getTools } from '../utils/tools';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import DayGroup from '../components/DayGroup.astro';
import StreamSidebar from '../components/StreamSidebar.astro';
import StreamTabs from '../components/StreamTabs.astro';
import Pagination from '../components/Pagination.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
  const paths: Array<{ params: { path: string | undefined } }> = [{ params: { path: undefined } }];
  for (let p = 2; p <= totalPages; p++) {
    paths.push({ params: { path: `page/${p}` } });
  }
  return paths;
}

function parsePageParam(path: string | undefined): number {
  if (!path) return 1;
  const match = path.match(/^page\/(\d+)$/);
  return match ? parseInt(match[1], 10) : 1;
}

const allPosts = await getCollection('posts');
const page = parsePageParam(Astro.params.path);

// Sort posts by date descending
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

const pageResult = paginate(sortedPosts, page, PAGE_SIZE);

// Group paginated posts by day
const dayGroups = groupPostsByDay(pageResult.items);
const sortedDays = Array.from(dayGroups.keys()).sort((a, b) => b.localeCompare(a));

// Prepare sidebar data: top tags by count
const allTags = getAllTags(allPosts);
const recentTags = Array.from(allTags.entries())
  .map(([tag, posts]) => [tag, posts.length] as [string, number])
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20);

// Recent content: chronological list for the sidebar (20 items)
const recentContent = sortedPosts.slice(0, 20).map((post) => ({
  id: post.id,
  title: getPostDisplayTitle(post),
  date: post.data.date,
}));

// Random content: shuffled list for the sidebar (10 items)
const randomContent = [...sortedPosts]
  .sort(() => Math.random() - 0.5)
  .slice(0, 10)
  .map((post) => ({
    id: post.id,
    title: getPostDisplayTitle(post),
    date: post.data.date,
  }));

// Recent tools for homepage
const recentTools = getTools().slice(0, 4);

// Load KaTeX CSS on the homepage if any recent post contains math syntax.
const mathRegex = /(?<!\$)\$[^$\n]+?\$(?!\$)|\$\$[\s\S]+?\$\$/;
const needsKatex = pageResult.items.some((post) => mathRegex.test(post.body || ''));

const pageTitle = page > 1 ? `${SITE_TITLE} - 第 ${page} 页` : `${SITE_TITLE} - ${SITE_DESCRIPTION}`;
---

<BaseLayout
  title={pageTitle}
  description={SITE_DESCRIPTION}
  canonical={Astro.url.toString()}
  showChat={false}
  needsKatex={needsKatex}
>
  <!-- Stream + Sidebar -->
  <section class="pt-10 pb-6 px-8">
    <div class="max-w-grid mx-auto">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        <!-- Main Stream -->
        <div class="flex-1 min-w-0">
          <StreamTabs currentType="all" />

          <!-- Search Bar -->
          <div class="mb-4">
            <div class="relative max-w-[560px]">
              <input
                type="search"
                id="searchInput"
                placeholder="搜索本站..."
                autocomplete="off"
                class="w-full py-2 pl-10 pr-3 text-sm border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] outline-none transition-all duration-200 ease font-sans rounded-md focus:border-[var(--text-primary)] focus:bg-[var(--white)]"
              />
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"/>
                  <path d="m21 21-4.3-4.3"/>
                </svg>
              </span>
            </div>
          </div>

          <div id="postsContainer" class="stream-container" data-type-filter="" data-type-total={allPosts.length}>
            {sortedDays.map((dayKey, dayIndex) => {
              const dayPosts = dayGroups.get(dayKey) || [];
              const entryStartIndex = sortedDays
                .slice(0, dayIndex)
                .reduce((acc, key) => acc + (dayGroups.get(key)?.length || 0), 0);
              return (
                <DayGroup
                  date={new Date(dayKey + 'T00:00:00')}
                  posts={dayPosts}
                  startIndex={entryStartIndex}
                />
              );
            })}
          </div>

          <!-- No Results Message -->
          <div id="noResults" class="hidden text-center py-16 px-8">
            <p class="font-serif-display text-2xl text-[var(--text-secondary)]">
              没有找到匹配的文章
            </p>
          </div>

          <Pagination
            currentPage={pageResult.currentPage}
            totalPages={pageResult.totalPages}
            baseUrl="/"
          />
        </div>

        <!-- Sidebar -->
        <StreamSidebar totalPosts={allPosts.length} recentTags={recentTags} recentContent={recentContent} randomContent={randomContent} recentTools={recentTools} />
      </div>
    </div>
  </section>

  <script src="../scripts/search.ts"></script>
</BaseLayout>
