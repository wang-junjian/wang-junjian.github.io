---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { normalizeTags, getRelatedPosts, calculateReadingTime, generateExcerpt, getPostDisplayTitle } from '../../utils/posts';
import RelatedPosts from '../../components/RelatedPosts.astro';
import PostSidebar from '../../components/PostSidebar.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const frontmatter = post.data;
const isQuote = frontmatter.type === 'quote';
const isNote = frontmatter.type === 'note';
const isLink = frontmatter.type === 'link';
const isRelease = frontmatter.type === 'release';
const isArticle = !isQuote && !isNote && !isLink && !isRelease;
const readingTime = frontmatter.readTime !== false ? calculateReadingTime(post.body) : 0;

const tags = normalizeTags(frontmatter.tags);
const relatedPosts = getRelatedPosts(post, allPosts);

const pageTitle = getPostDisplayTitle(post);
const pageDescription = isArticle
  ? (frontmatter.excerpt || `${pageTitle} - ${SITE_DESCRIPTION}`)
  : (generateExcerpt(post.body, 200) || `${pageTitle} - ${SITE_DESCRIPTION}`);
const pageImage = frontmatter.image ? String(frontmatter.image) : undefined;
const postDate = frontmatter.date ? new Date(frontmatter.date) : new Date();
const sourceTitleHtml = frontmatter.sourceTitle
  ? marked.parseInline(frontmatter.sourceTitle, { async: false })
  : '';

const jsonLd = isQuote
  ? {
      '@context': 'https://schema.org',
      '@type': 'Quotation',
      text: post.body || '',
      ...(frontmatter.author && {
        author: {
          '@type': 'Person',
          name: frontmatter.author,
        },
      }),
      url: Astro.url.toString(),
      datePublished: postDate.toISOString(),
      ...(frontmatter.source && { isBasedOn: frontmatter.source }),
    }
  : isLink || isRelease
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: pageTitle,
        description: pageDescription,
        url: Astro.url.toString(),
        datePublished: postDate.toISOString(),
        author: {
          '@type': 'Person',
          name: '军舰',
        },
        publisher: {
          '@type': 'Organization',
          name: SITE_TITLE,
          logo: {
            '@type': 'ImageObject',
            url: new URL('/favicon.svg', Astro.site || Astro.url).toString(),
          },
        },
        ...(frontmatter.linkUrl && {
          mainEntityOfPage: {
            '@type': 'WebPage',
            '@id': frontmatter.linkUrl,
          },
        }),
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: pageTitle,
        description: pageDescription,
        url: Astro.url.toString(),
        datePublished: postDate.toISOString(),
        author: {
          '@type': 'Person',
          name: '军舰',
        },
        publisher: {
          '@type': 'Organization',
          name: SITE_TITLE,
          logo: {
            '@type': 'ImageObject',
            url: new URL('/favicon.svg', Astro.site || Astro.url).toString(),
          },
        },
        ...(pageImage && {
          image: {
            '@type': 'ImageObject',
            url: new URL(pageImage, Astro.site || Astro.url).toString(),
          },
        }),
      };
---

<BaseLayout
  title={`${pageTitle} - ${SITE_TITLE}`}
  description={pageDescription}
  image={pageImage}
  canonical={Astro.url.toString()}
  type="article"
  date={postDate}
  author="军舰"
  needsKatex={isArticle}
>
  <link rel="stylesheet" href="/styles/prose.css" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <article>
    <section class="pt-6 pb-10 px-8">
      <div class="max-w-grid mx-auto flex flex-col lg:flex-row gap-8 lg:gap-12">
        {isArticle && (
          <div class="toc-wrapper print:hidden">
            <TableOfContents headings={headings} fixed={true} side="left" />
          </div>
        )}

        <div class="flex-1 min-w-0">
          {isArticle && (
            <h1 class="font-serif-display text-[1.5rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[var(--text-primary)] mb-6">
              {pageTitle}
            </h1>
          )}

          {isQuote ? (
            <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
              <div class="prose">
                <Content />
              </div>

              <figcaption class="quote-attribution">
                <span aria-hidden="true">—</span>
                {frontmatter.author ? (
                  frontmatter.source ? (
                    <a href={frontmatter.source} target="_blank" rel="noopener noreferrer">{frontmatter.author}</a>
                  ) : (
                    <span>{frontmatter.author}</span>
                  )
                ) : (
                  <span>未知作者</span>
                )}
                {frontmatter.sourceTitle && <span>, <span set:html={sourceTitleHtml} /></span>}
                {frontmatter.context && <span>, {frontmatter.context}</span>}
              </figcaption>
            </div>
          ) : isLink ? (
            <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
              <div class="link-detail-header">
                <h1 class="link-detail-title">
                  {frontmatter.linkUrl ? (
                    <a href={frontmatter.linkUrl} target="_blank" rel="noopener noreferrer">
                      {pageTitle}
                      <span class="link-external-icon" aria-hidden="true">🔗</span>
                    </a>
                  ) : (
                    pageTitle
                  )}
                </h1>
              </div>

              {post.body && (
                <div class="link-detail-body prose">
                  <Content />
                </div>
              )}
            </div>
          ) : isRelease ? (
            <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
              <div class="release-detail-header">
                <h1 class="release-detail-title">
                  {frontmatter.linkUrl ? (
                    <a href={frontmatter.linkUrl} target="_blank" rel="noopener noreferrer">
                      {pageTitle}
                      <span class="link-external-icon" aria-hidden="true">🔗</span>
                    </a>
                  ) : (
                    pageTitle
                  )}
                </h1>
              </div>

              {post.body && (
                <div class="release-detail-body prose">
                  <Content />
                </div>
              )}
            </div>
          ) : (
            <div class="prose animate-fade-in-up" style="animation-delay: 0.1s;">
              <Content />
            </div>
          )}

          <div class="giscus-container py-8">
            <script
              is:inline
              src="https://giscus.app/client.js"
              data-repo="wang-junjian/wang-junjian.github.io"
              data-repo-id="MDEwOlJlcG9zaXRvcnkzMDQxNzc5NjE="
              data-category="Comments"
              data-category-id="DIC_kwDOEiFjKc4C8psx"
              data-mapping="pathname"
              data-strict="0"
              data-reactions-enabled="1"
              data-emit-metadata="0"
              data-input-position="bottom"
              data-theme="preferred_color_scheme"
              data-lang="zh-CN"
              data-loading="eager"
              crossorigin="anonymous"
              async>
            </script>
          </div>

          <RelatedPosts posts={relatedPosts} />
        </div>

        <PostSidebar
          postId={post.id}
          date={frontmatter.date}
          readingTime={readingTime}
          tags={tags}
          class="print:hidden"
        />
      </div>
    </section>
  </article>

  <script src="../../scripts/post-scripts.ts"></script>

  <script is:inline>
    (function() {
      const btn = document.getElementById('postActionsBtn');
      const menu = document.getElementById('postActionsMenu');
      if (!btn || !menu) return;

      const items = Array.from(menu.querySelectorAll('[role="menuitem"]'));

      function openMenu() {
        menu.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        if (items[0]) {
          items[0].focus();
        }
      }

      function closeMenu(returnFocus) {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (returnFocus !== false) {
          btn.focus();
        }
      }

      function toggleMenu() {
        if (menu.classList.contains('hidden')) {
          openMenu();
        } else {
          closeMenu();
        }
      }

      function focusNext(current) {
        const idx = items.indexOf(current);
        const next = items[(idx + 1) % items.length];
        if (next) next.focus();
      }

      function focusPrev(current) {
        const idx = items.indexOf(current);
        const prev = items[(idx - 1 + items.length) % items.length];
        if (prev) prev.focus();
      }

      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleMenu();
      });

      btn.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp' || e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (menu.classList.contains('hidden')) {
            openMenu();
            if (e.key === 'ArrowUp') {
              focusPrev(items[0]);
            }
          }
        }
      });

      menu.addEventListener('keydown', function(e) {
        const current = document.activeElement;
        if (!items.includes(current)) return;

        switch (e.key) {
          case 'Escape':
            e.preventDefault();
            closeMenu();
            break;
          case 'ArrowDown':
            e.preventDefault();
            focusNext(current);
            break;
          case 'ArrowUp':
            e.preventDefault();
            focusPrev(current);
            break;
          case 'Home':
            e.preventDefault();
            if (items[0]) items[0].focus();
            break;
          case 'End':
            e.preventDefault();
            if (items[items.length - 1]) items[items.length - 1].focus();
            break;
          case 'Tab':
            e.preventDefault();
            closeMenu();
            break;
        }
      });

      document.addEventListener('click', function(e) {
        if (!btn.contains(e.target) && !menu.contains(e.target)) {
          closeMenu(false);
        }
      });

      const copyBtn = menu.querySelector('[data-action="copy-md"]');
      if (copyBtn) {
        copyBtn.addEventListener('click', function() {
          fetch(window.location.pathname.replace(/\/$/, '') + '.md')
            .then(function(res) { return res.text(); })
            .then(function(text) {
              var cleaned = text.replace(/^---\s*[\r\n]+[\s\S]*?[\r\n]+---\s*[\r\n]*/, '');
              return navigator.clipboard.writeText(cleaned);
            })
            .then(function() {
              var span = copyBtn.querySelector('span');
              var original = span.textContent;
              span.textContent = '已复制！';
              setTimeout(function() { span.textContent = original; }, 2000);
            })
            .catch(function(err) { console.error('复制失败', err); });
          closeMenu();
        });
      }

      var chatBtn = menu.querySelector('[data-action="chat"]');
      if (chatBtn) {
        chatBtn.addEventListener('click', function() {
          var h1 = document.querySelector('h1');
          var title = h1 ? h1.textContent.trim() : '这篇文章';
          var prompt = '请帮我分析这篇文章《' + title + '》的核心内容。';
          if (window.__aiChat) {
            window.__aiChat.sendMessage(prompt);
          } else {
            alert('AIChat 尚未加载，请稍后再试');
          }
          closeMenu();
        });
      }

      var exportPdfBtn = menu.querySelector('[data-action="export-pdf"]');
      if (exportPdfBtn) {
        exportPdfBtn.addEventListener('click', function() {
          var h1 = document.querySelector('h1');
          var title = h1 ? h1.textContent.trim() : document.title;
          var originalTitle = document.title;
          document.title = title;
          window.print();
          document.title = originalTitle;
          closeMenu();
        });
      }
    })();
  </script>
</BaseLayout>
