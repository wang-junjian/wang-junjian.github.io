---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getAllCategories, formatDate } from '../utils/posts';

const posts = await getCollection('posts');
const categories = getAllCategories(posts);

// Sort categories by post count descending
const sortedCategories = Array.from(categories.entries()).sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="分类 - 军舰日志">
  <section class="py-16 px-8 bg-white border-b border-[var(--border)]">
    <div class="max-w-[1300px] mx-auto">
      <a href="/" class="inline-flex items-center gap-2 text-[var(--text-secondary)] no-underline text-sm mb-8 transition-colors duration-200 hover:text-[var(--accent)]">
        <span>←</span>
        返回首页
      </a>
      <h1 class="font-['Newsreader',_Georgia,_serif] text-[3.5rem] font-semibold leading-[1.1] tracking-[-0.03em] mb-2 animate-fade-in-up">
        分类
      </h1>
      <p class="text-[var(--text-secondary)] text-lg animate-fade-in-up" style="animation-delay: 0.1s;">
        共 {categories.size} 个分类，{posts.length} 篇文章
      </p>
    </div>
  </section>

  <!-- Category Cloud -->
  <section class="py-12 px-8 bg-[var(--bg-primary)] border-b border-[var(--border)]">
    <div class="max-w-[1300px] mx-auto">
      <div class="flex flex-wrap gap-3 animate-fade-in-up" style="animation-delay: 0.15s;">
        {sortedCategories.map(([category, catPosts]) => {
          const count = catPosts.length;
          const size = Math.min(2, 0.85 + (count / 30));
          const opacity = Math.min(1, 0.6 + (count / 50));
          return (
            <a
              href={`#category-${encodeURIComponent(category)}`}
              class="px-4 py-2 bg-white border border-[var(--border)] text-[var(--text-primary)] no-underline rounded-none transition-all duration-200 tabular-nums hover:border-[var(--text-primary)] hover:-translate-y-0.5 hover:shadow-md"
              style={`font-size: ${size}rem; opacity: ${opacity};`}
            >
              {category}
              <span class="ml-2 text-[0.75em] text-[var(--text-secondary)]">({count})</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Detailed Category List -->
  <section class="py-16 px-8">
    <div class="max-w-[1300px] mx-auto">
      <div class="grid gap-16">
        {sortedCategories.map(([category, catPosts], index) => (
          <section id={`category-${encodeURIComponent(category)}`} class="animate-fade-in-up border-b border-[var(--border)] pb-12" style={`animation-delay: ${0.2 + index * 0.03}s;`}>
            <div class="flex items-baseline justify-between mb-8 gap-4 flex-wrap">
              <h2 class="font-['Newsreader',_Georgia,_serif] text-[2rem] font-semibold tracking-[-0.02em]">
                {category}
              </h2>
              <span class="text-[var(--text-secondary)] text-sm tabular-nums">
                {catPosts.length} 篇文章
              </span>
            </div>

            <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-8">
              {catPosts.slice(0, 6).map((post) => (
                <article>
                  <time class="block text-xs uppercase tracking-[0.08em] text-[var(--text-secondary)] mb-2">
                    {formatDate(post.data.date)}
                  </time>
                  <h3 class="font-['Newsreader',_Georgia,_serif] text-xl font-medium leading-[1.4] tracking-[-0.01em]">
                    <a href={`/posts/${post.id}`} class="text-[var(--text-primary)] no-underline transition-colors duration-200 hover:text-[var(--accent)]">
                      {post.data.title || post.id}
                    </a>
                  </h3>
                </article>
              ))}
            </div>

            {catPosts.length > 6 && (
              <p class="mt-6 text-[var(--text-secondary)] text-sm">
                还有 {catPosts.length - 6} 篇文章...
              </p>
            )}
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
