---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

const cleanBase = baseUrl.replace(/\/$/, '');

function pageUrl(page: number): string {
  if (page <= 1) return `${cleanBase}/`;
  return `${cleanBase}/page/${page}/`;
}
---

{
  totalPages > 1 && (
    <nav
      class="pagination-nav py-10 flex items-center justify-center gap-6 text-sm"
      aria-label="分页导航"
    >
      {currentPage > 1 ? (
        <a
          href={pageUrl(currentPage - 1)}
          class="text-[var(--text-secondary)] no-underline hover:text-[var(--accent)] transition-colors"
        >
          ← 上一页
        </a>
      ) : (
        <span class="text-[var(--border)] cursor-not-allowed">← 上一页</span>
      )}

      <span class="text-[var(--text-secondary)] tabular-nums font-sans">
        第 {currentPage} / {totalPages} 页
      </span>

      {currentPage < totalPages ? (
        <a
          href={pageUrl(currentPage + 1)}
          class="text-[var(--text-secondary)] no-underline hover:text-[var(--accent)] transition-colors"
        >
          下一页 →
        </a>
      ) : (
        <span class="text-[var(--border)] cursor-not-allowed">下一页 →</span>
      )}
    </nav>
  )
}
