---
import type { CollectionEntry } from 'astro:content';

interface Props {
  taxonomyType: 'category' | 'tag';
  items: [string, CollectionEntry<'posts'>[]][];
  totalPosts: number;
  labelSingular: string;
  labelPlural: string;
}

const { items } = Astro.props;

// Sort tags alphabetically, like Simon Willison's /tags/ page.
const sortedItems = [...items].sort((a, b) => a[0].localeCompare(b[0], 'zh-CN'));

function getPopularityClass(count: number): string {
  if (count >= 100) return 'ultra-popular';
  if (count >= 50) return 'very-popular';
  if (count >= 30) return 'more-than-just-popular';
  if (count >= 20) return 'popular';
  if (count >= 10) return 'somewhat-more-popular';
  if (count >= 5) return 'somewhat-popular';
  if (count >= 2) return 'not-very-popular';
  return 'not-popular-at-all';
}
---

<section class="tag-cloud-section pt-10 pb-20 px-8">
  <div class="max-w-grid mx-auto">
    <div class="max-w-2xl mx-auto mb-10">
      <div class="relative">
        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] pointer-events-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </div>
        <input
          type="search"
          id="tagSearchInput"
          placeholder={`搜索 ${sortedItems.length} 个标签...`}
          class="w-full pl-12 pr-4 py-4 rounded-2xl border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] focus:outline-none focus-visible:outline-none focus:border-[var(--accent)] transition-colors"
          style="outline: none !important; box-shadow: none !important;"
          autocomplete="off"
        />
      </div>
      <p id="tagSearchCount" class="text-center text-sm text-[var(--text-secondary)] mt-3 hidden"></p>
    </div>

    <p id="tagcloud" class="tag-cloud">
      {sortedItems.map(([name, namePosts]) => {
        const count = namePosts.length;
        return (
          <a
            href={`/tags/${encodeURIComponent(name)}/`}
            class={`item-tag ${getPopularityClass(count)}`}
            title={`${count} 篇文章`}
            data-name={name.toLowerCase()}
          >
            {name}
            <span class="tag-count">{count}</span>
          </a>
        );
      })}
    </p>
  </div>
</section>

<script>
  (function () {
    const input = document.getElementById('tagSearchInput');
    const cloud = document.getElementById('tagcloud');
    const countEl = document.getElementById('tagSearchCount');
    if (!input || !cloud) return;

    const tags = Array.from(cloud.querySelectorAll('.item-tag'));
    const totalTags = tags.length;

    function filterTags() {
      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;

      tags.forEach((tag) => {
        const name = tag.dataset.name || '';
        const matches = name.includes(query);
        tag.style.display = matches ? '' : 'none';
        if (matches) visibleCount++;
      });

      if (countEl) {
        if (query) {
          countEl.textContent = `找到 ${visibleCount} / ${totalTags} 个标签`;
          countEl.classList.remove('hidden');
        } else {
          countEl.classList.add('hidden');
        }
      }
    }

    input.addEventListener('input', filterTags);

    // Global / shortcut to focus tag search
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement?.id !== 'tagSearchInput') {
        e.preventDefault();
        input.focus();
      }
    });
  })();
</script>

<style>
  .tag-cloud-section {
    min-height: 60vh;
  }

  .tag-cloud {
    font-size: 1.2em;
    line-height: 2.2em;
    text-align: center;
    margin: 0;
  }

  .item-tag {
    display: inline-block;
    background-color: var(--bg-secondary, rgba(0, 0, 0, 0.03));
    padding: 0.25rem 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-primary);
    margin-right: 0.4rem;
    margin-bottom: 0.6rem;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  :global(.dark) .item-tag {
    background-color: rgba(255, 255, 255, 0.04);
  }

  .item-tag:hover {
    background-color: var(--accent);
    border-color: var(--accent);
    color: var(--white, #fff);
    transform: translateY(-1px);
  }

  .tag-count {
    color: var(--text-secondary);
    font-size: 0.6em;
    vertical-align: middle;
    margin-left: 0.35em;
    opacity: 0.8;
  }

  .item-tag:hover .tag-count {
    color: inherit;
    opacity: 1;
  }

  /* Popularity levels matching Simon Willison's tag cloud */
  .item-tag.not-popular-at-all {
    font-size: 0.7em;
  }
  .item-tag.not-very-popular {
    font-size: 0.89em;
  }
  .item-tag.somewhat-popular {
    font-size: 1.07em;
  }
  .item-tag.somewhat-more-popular {
    font-size: 1.26em;
  }
  .item-tag.popular {
    font-size: 1.44em;
  }
  .item-tag.more-than-just-popular {
    font-size: 1.63em;
  }
  .item-tag.very-popular {
    font-size: 1.81em;
  }
  .item-tag.ultra-popular {
    font-size: 2em;
  }
</style>
