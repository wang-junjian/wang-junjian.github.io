---
import { marked } from 'marked';
import { formatTime, normalizeTags } from '../utils/posts';

interface Props {
  id: string;
  body?: string;
  date: Date;
  tags?: string[] | string | null;
  showDate?: boolean;
  index?: number;
}

const {
  id,
  body,
  date,
  tags,
  showDate = true,
  index = 0,
} = Astro.props;

const noteHtml = body
  ? marked.parse(body, { async: false, gfm: true })
  : '';

const href = `/posts/${id}/`;

const tagList = normalizeTags(tags);
---

<article
  class="post-item note-card"
  style={`animation-delay: ${((index % 6) * 0.1).toFixed(1)}s;`}
  data-id={id}
>
  <div class="type-badge type-badge-note">笔记</div>

  <div class="note-text" set:html={noteHtml} />

  <div class="entry-meta">
    {showDate && (
      <a href={href} class="post-time-link">
        <time datetime={date.toISOString()}>
          {formatTime(date)}
        </time>
      </a>
    )}

    {tagList.length > 0 && (
      <>
        <span class="meta-separator" aria-hidden="true">·</span>
        <div class="entry-tags">
          {tagList.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}/`} class="entry-tag">{tag}</a>
          ))}
        </div>
      </>
    )}
  </div>
</article>
