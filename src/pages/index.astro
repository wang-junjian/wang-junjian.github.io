---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/posts';

const posts = await getCollection('posts');

// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});
---

<BaseLayout title="军舰日志 - 务实程序员的自我修炼">
  <!-- Header with Search -->
  <section class="pt-20 pb-12 px-8 bg-white border-b border-[var(--border)]">
    <div class="max-w-[800px] mx-auto text-center animate-fade-in-up">
      <!-- Search Box -->
      <div class="relative max-w-[500px] mx-auto">
        <input
          type="text"
          id="searchInput"
          placeholder="搜索文章..."
          class="w-full py-4 pl-14 pr-6 text-base border-2 border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] outline-none transition-all duration-200 ease font-sans focus:border-[var(--text-primary)] focus:bg-white"
        />
        <span class="absolute left-5 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] text-xl pointer-events-none">
          🔍
        </span>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16 px-8">
    <div class="max-w-[1300px] mx-auto">
      <div class="flex items-baseline justify-between mb-12">
        <h2 class="font-['Newsreader',_Georgia,_serif] text-2xl font-semibold tracking-[-0.02em]">
          全部文章
        </h2>
        <span id="postCount" class="text-[var(--text-secondary)] text-sm tabular-nums">
          {sortedPosts.length} 篇
        </span>
      </div>

      <div id="postsContainer" class="grid grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-12">
        {sortedPosts.map((post, index) => (
          <article
            class="post-item animate-fade-in-up flex flex-col gap-4 pb-8 border-b border-[var(--border)]"
            style={`animation-delay: ${(index % 6) * 0.1}s;`}
            data-title={(post.data.title || post.id || '').toLowerCase()}
            data-excerpt={(post.data.excerpt || '').toLowerCase()}
          >
            <time class="text-xs uppercase tracking-[0.08em] text-[var(--text-secondary)] font-medium">
              {formatDate(post.data.date)}
            </time>
            <h3 class="font-['Newsreader',_Georgia,_serif] text-2xl font-semibold leading-[1.3] tracking-[-0.02em]">
              <a href={`/posts/${post.id}`} class="text-[var(--text-primary)] no-underline transition-colors duration-200 hover:text-[var(--accent)]">
                {post.data.title || post.id}
              </a>
            </h3>
            {post.data.excerpt && (
              <p class="text-[var(--text-secondary)] text-[0.95rem] leading-relaxed">
                {post.data.excerpt}
              </p>
            )}
            <a href={`/posts/${post.id}`} class="inline-flex items-center gap-2 text-[var(--text-primary)] no-underline text-sm font-medium mt-auto w-fit group">
              阅读
              <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
            </a>
          </article>
        ))}
      </div>

      <!-- No Results Message -->
      <div id="noResults" class="hidden text-center py-16 px-8">
        <p class="font-['Newsreader',_Georgia,_serif] text-2xl text-[var(--text-secondary)]">
          没有找到匹配的文章
        </p>
      </div>
    </div>
  </section>

  <!-- Search JavaScript -->
  <script is:inline src="/js/search.js"></script>
</BaseLayout>
