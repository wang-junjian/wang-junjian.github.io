---
interface Props {
  currentType: string;
}

const { currentType } = Astro.props;

const tabs = [
  { type: 'all', label: '全部', href: '/' },
  { type: 'article', label: '文档', href: '/articles/' },
  { type: 'quote', label: '引用', href: '/quotes/' },
  { type: 'note', label: '笔记', href: '/notes/' },
  { type: 'link', label: '链接', href: '/links/' },
  { type: 'release', label: '发布', href: '/releases/' },
];
---

<nav class="stream-tabs" aria-label="内容类型">
  <div class="stream-tabs-inner">
    {tabs.map((tab) => {
      const isActive = tab.type === currentType;
      return (
        <a
          href={tab.href}
          class={isActive ? 'active' : ''}
          aria-current={isActive ? 'page' : undefined}
        >
          {tab.label}
        </a>
      );
    })}
  </div>
</nav>

<style>
  .stream-tabs {
    margin-bottom: 1rem;
  }

  .stream-tabs-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .stream-tabs-inner::-webkit-scrollbar {
    display: none;
  }

  .stream-tabs a {
    flex-shrink: 0;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  .stream-tabs a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.3s ease;
  }

  .stream-tabs a:hover,
  .stream-tabs a.active {
    color: var(--text-primary);
  }

  .stream-tabs a:hover::after,
  .stream-tabs a.active::after {
    width: 100%;
  }
</style>
