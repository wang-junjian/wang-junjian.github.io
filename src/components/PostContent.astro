---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  Content: (_props: Record<string, unknown>) => unknown;
  pageTitle: string;
}

const { post, Content, pageTitle } = Astro.props;
const frontmatter = post.data;

const isQuote = frontmatter.type === 'quote';
const isLink = frontmatter.type === 'link';
const isRelease = frontmatter.type === 'release';
const isArticle = !isQuote && !isLink && !isRelease;
---

{isArticle && (
  <h1 class="font-serif-display text-[1.5rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[var(--text-primary)] mb-6">
    {pageTitle}
  </h1>
)}

{isQuote ? (
  <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
    <div class="link-detail-header">
      <h1 class="link-detail-title">
        {frontmatter.linkUrl ? (
          <a href={frontmatter.linkUrl} target="_blank" rel="noopener noreferrer">
            {pageTitle}
            <span class="link-external-icon" aria-hidden="true">🔗</span>
          </a>
        ) : (
          pageTitle
        )}
      </h1>
    </div>

    <div class="prose">
      <Content />
    </div>

    <figcaption class="quote-attribution">
      <span aria-hidden="true">—</span>
      {frontmatter.author ? <span>{frontmatter.author}</span> : <span>未知作者</span>}
      {frontmatter.context && <span>, {frontmatter.context}</span>}
    </figcaption>
  </div>
) : isLink ? (
  <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
    <div class="link-detail-header">
      <h1 class="link-detail-title">
        {frontmatter.linkUrl ? (
          <a href={frontmatter.linkUrl} target="_blank" rel="noopener noreferrer">
            {pageTitle}
            <span class="link-external-icon" aria-hidden="true">🔗</span>
          </a>
        ) : (
          pageTitle
        )}
      </h1>
    </div>

    {post.body && (
      <div class="link-detail-body prose">
        <Content />
      </div>
    )}
  </div>
) : isRelease ? (
  <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
    <div class="release-detail-header">
      <h1 class="release-detail-title">
        {frontmatter.linkUrl ? (
          <a href={frontmatter.linkUrl} target="_blank" rel="noopener noreferrer">
            {pageTitle}
            <span class="link-external-icon" aria-hidden="true">🔗</span>
          </a>
        ) : (
          pageTitle
        )}
      </h1>
    </div>

    {post.body && (
      <div class="release-detail-body prose">
        <Content />
      </div>
    )}
  </div>
) : (
  <div class="prose animate-fade-in-up" style="animation-delay: 0.1s;">
    <Content />
  </div>
)}
