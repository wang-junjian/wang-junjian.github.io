---
interface Props {
  totalPosts: number;
  recentTags?: Array<[string, number]>;
  recentContent?: Array<{ id: string; title: string; date: Date | string }>;
  randomContent?: Array<{ id: string; title: string; date: Date | string }>;
  randomTools?: Array<{ file: string; title: string; excerpt?: string; tags?: string[]; date?: string }>;
}

const { totalPosts, recentTags = [], recentContent = [], randomContent = [], randomTools = [] } = Astro.props;

const firstYear = 2018; // Approximate start year; can be made dynamic later
---

<aside class="stream-sidebar">
  {randomTools.length > 0 && (
    <div class="sidebar-section">
      <h3>随机工具</h3>
      <ul class="sidebar-tool-list">
        {randomTools.map((tool) => (
          <li>
            <a href={`/tools/${tool.file}`} class="sidebar-tool-link" target="_blank" rel="noopener noreferrer">
              <span class="sidebar-tool-title">{tool.title}</span>
              {tool.excerpt && <span class="sidebar-tool-excerpt">{tool.excerpt}</span>}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {randomContent.length > 0 && (
    <div class="sidebar-section">
      <h3>随机内容</h3>
      <ul class="sidebar-highlights">
        {randomContent.map((post) => (
          <li>
            <a href={`/posts/${post.id}/`} class="sidebar-highlight-link">
              <span class="sidebar-highlight-title">{post.title || post.id}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {recentContent.length > 0 && (
    <div class="sidebar-section">
      <h3>最近内容</h3>
      <ul class="sidebar-highlights">
        {recentContent.map((post) => (
          <li>
            <a href={`/posts/${post.id}/`} class="sidebar-highlight-link">
              <span class="sidebar-highlight-title">{post.title || post.id}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {recentTags.length > 0 && (
    <div class="sidebar-section">
      <h3>热门标签</h3>
      <div class="sidebar-tag-cloud">
        {recentTags.map(([tag, count]) => (
          <a href={`/tags/${encodeURIComponent(tag)}/`} class="sidebar-tag">
            {tag}
            <span class="sidebar-tag-count">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="sidebar-section">
    <h3>订阅</h3>
    <a href="/rss.xml" class="sidebar-link">RSS 订阅</a>
  </div>

  <div class="sidebar-section">
    <h3>统计</h3>
    <p class="sidebar-stat">
      <span id="postCount" class="sidebar-stat-number">{totalPosts.toLocaleString('zh-CN')}</span> 篇文章
    </p>
    <p class="sidebar-stat">
      始于 {firstYear} 年
    </p>
  </div>
</aside>
