---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';

const slidesDir = join(process.cwd(), 'slides');
const files = readdirSync(slidesDir)
  .filter((f) => f.endsWith('.md') && !f.startsWith('.'))
  .sort((a, b) => a.localeCompare(b));

const slides = files.map((file) => {
  const raw = readFileSync(join(slidesDir, file), 'utf-8');
  const titleMatch = raw.match(/^#\s+(.+)$/m);
  const title = titleMatch ? titleMatch[1].trim() : file.replace(/\.md$/, '');
  return { id: file.replace(/\.md$/, ''), title };
});
---

<BaseLayout title="幻灯片 - 军舰日志">
  <section class="pt-20 pb-12 px-8 bg-white border-b border-[var(--border)]">
    <div class="max-w-[800px] mx-auto text-center animate-fade-in-up">
      <h1 class="font-['Newsreader',_Georgia,_serif] text-4xl font-semibold leading-[1.1] tracking-[-0.03em] text-[var(--text-primary)]">
        幻灯片
      </h1>
      <p class="text-[var(--text-secondary)] mt-4">
        人工智能技术分享
      </p>
    </div>
  </section>

  <section class="py-16 px-8">
    <div class="max-w-[1300px] mx-auto">
      <div class="flex items-baseline justify-between mb-12">
        <h2 class="font-['Newsreader',_Georgia,_serif] text-2xl font-semibold tracking-[-0.02em]">
          全部幻灯片
        </h2>
        <span class="text-[var(--text-secondary)] text-sm tabular-nums">
          {slides.length} 篇
        </span>
      </div>

      <div class="grid grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-12">
        {slides.map((slide, index) => (
          <article
            class="animate-fade-in-up flex flex-col gap-4 pb-8 border-b border-[var(--border)]"
            style={`animation-delay: ${(index % 6) * 0.1}s;`}
          >
            <h3 class="font-['Newsreader',_Georgia,_serif] text-2xl font-semibold leading-[1.3] tracking-[-0.02em]">
              <a
                href={`/slides/${encodeURIComponent(slide.id)}`}
                class="text-[var(--text-primary)] no-underline transition-colors duration-200 hover:text-[var(--accent)]"
              >
                {slide.title}
              </a>
            </h3>
            <a
              href={`/slides/${encodeURIComponent(slide.id)}`}
              class="inline-flex items-center gap-2 text-[var(--text-primary)] no-underline text-sm font-medium mt-auto w-fit group"
            >
              查看幻灯片
              <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
