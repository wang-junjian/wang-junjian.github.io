---
---

<style is:global>
.ai-chat-widget {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 9999;
  font-family: inherit;
}

.ai-chat-toggle {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.ai-chat-toggle:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
}

.ai-chat-window {
  position: absolute;
  bottom: 76px;
  right: 0;
  width: 460px;
  height: 750px;
  background: var(--white, #ffffff);
  border-radius: 16px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  display: none;
  flex-direction: column;
}

.ai-chat-window.open {
  display: flex;
}

.ai-chat-header {
  padding: 12px 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.ai-chat-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.ai-chat-avatar {
  font-size: 22px;
}

.ai-chat-title {
  font-size: 14px;
  font-weight: 600;
  margin: 0;
}

.ai-chat-subtitle {
  font-size: 11px;
  opacity: 0.8;
  margin: 0;
}

.ai-chat-header-actions {
  display: flex;
  gap: 6px;
}

.ai-chat-header-btn {
  background: none;
  border: none;
  color: white;
  font-size: 16px;
  cursor: pointer;
  padding: 4px;
  opacity: 0.8;
  transition: opacity 0.2s;
}

.ai-chat-header-btn:hover {
  opacity: 1;
}

.ai-chat-status {
  padding: 6px 12px;
  font-size: 11px;
  background: #fef3c7;
  color: #92400e;
  flex-shrink: 0;
}

.ai-chat-status.success {
  background: #d1fae5;
  color: #065f46;
}

.ai-chat-config {
  padding: 12px;
  background: #f8fafc;
  border-bottom: 1px solid var(--border, #e0ddd8);
  flex-shrink: 0;
  overflow-y: auto;
  max-height: 50vh;
  display: none;
}

.ai-chat-config.open {
  display: block;
}

.ai-chat-config-group {
  margin-bottom: 10px;
}

.ai-chat-config-label {
  display: block;
  font-size: 12px;
  color: var(--text-secondary, #666666);
  margin-bottom: 3px;
}

.ai-chat-config-input {
  width: 100%;
  padding: 7px 10px;
  border: 1px solid var(--border, #e0ddd8);
  border-radius: 6px;
  font-size: 13px;
  outline: none;
  background: var(--white, #ffffff);
  color: var(--text-primary, #1a1a1a);
  box-sizing: border-box;
}

.ai-chat-config-input:focus {
  border-color: #667eea;
}

.ai-chat-save-btn {
  width: 100%;
  padding: 8px;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  margin-top: 6px;
}

.ai-chat-config-note {
  font-size: 10px;
  color: var(--text-secondary, #666666);
  margin-top: 6px;
}

.ai-chat-messages {
  flex: 1;
  padding: 12px;
  overflow-y: auto;
  background: #fafafa;
}

.ai-chat-message {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
  align-items: flex-start;
}

.ai-chat-message-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

.ai-chat-message.user .ai-chat-message-avatar {
  background: #f0e2e7;
}

.ai-chat-message.assistant .ai-chat-message-avatar {
  background: #667eea;
}

.ai-chat-message-content {
  flex: 1;
  padding: 10px 12px;
  border-radius: 10px;
  line-height: 1.5;
  font-size: 13px;
  word-wrap: break-word;
}

.ai-chat-message.user .ai-chat-message-content {
  background: #e2e8f0;
}

.ai-chat-message.assistant .ai-chat-message-content {
  background: var(--white, #ffffff);
  border: 1px solid var(--border, #e0ddd8);
}

.ai-chat-message-content h1,
.ai-chat-message-content h2,
.ai-chat-message-content h3,
.ai-chat-message-content h4 {
  margin-top: 0.8em;
  margin-bottom: 0.4em;
  font-weight: 600;
  line-height: 1.25;
}

.ai-chat-message-content h1 { font-size: 1.4em; }
.ai-chat-message-content h2 { font-size: 1.2em; }
.ai-chat-message-content h3 { font-size: 1.1em; }
.ai-chat-message-content h4 { font-size: 1em; }

.ai-chat-message-content p {
  margin-top: 0.4em;
  margin-bottom: 0.4em;
}

.ai-chat-message-content a {
  color: #667eea;
  text-decoration: underline;
}

.ai-chat-message-content strong {
  font-weight: 600;
}

.ai-chat-message-content em {
  font-style: italic;
}

.ai-chat-message-content ul,
.ai-chat-message-content ol {
  margin-top: 0.4em;
  margin-bottom: 0.4em;
  padding-left: 1.4em;
}

.ai-chat-message-content li {
  margin-top: 0.2em;
  margin-bottom: 0.2em;
}

.ai-chat-message-content code {
  background: #f1f5f9;
  padding: 0.1em 0.3em;
  border-radius: 3px;
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  font-size: 0.85em;
}

.ai-chat-message-content pre {
  background: #1e293b;
  color: #e2e8f0;
  padding: 0.8em;
  border-radius: 6px;
  overflow-x: auto;
  margin-top: 0.6em;
  margin-bottom: 0.6em;
}

.ai-chat-message-content pre code {
  background: none;
  padding: 0;
  color: inherit;
  font-size: 0.85em;
}

.ai-chat-input-area {
  padding: 12px;
  border-top: 1px solid var(--border, #e0ddd8);
  background: var(--white, #ffffff);
  flex-shrink: 0;
}

.ai-chat-input-wrapper {
  display: flex;
  gap: 10px;
  align-items: flex-end;
}

.ai-chat-input {
  flex: 1;
  padding: 10px 12px;
  border: 1px solid var(--border, #e0ddd8);
  border-radius: 10px;
  font-size: 13px;
  resize: none;
  outline: none;
  font-family: inherit;
  line-height: 1.4;
  max-height: 100px;
}

.ai-chat-input:focus {
  border-color: #667eea;
}

.ai-chat-input:disabled {
  background: #f1f5f9;
  cursor: not-allowed;
}

.ai-chat-send-btn {
  padding: 10px 16px;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.2s;
  flex-shrink: 0;
}

.ai-chat-send-btn:hover:not(:disabled) {
  background: #5a6fd6;
}

.ai-chat-send-btn:disabled {
  background: #cbd5e1;
  cursor: not-allowed;
}

.ai-chat-loading {
  display: inline-flex;
  gap: 3px;
}

.ai-chat-loading span {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--text-secondary, #666666);
  animation: ai-chat-bounce 1.4s infinite ease-in-out both;
}

.ai-chat-loading span:nth-child(1) {
  animation-delay: -0.32s;
}

.ai-chat-loading span:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes ai-chat-bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.quick-questions {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 10px;
}

.quick-question-btn {
  padding: 5px 10px;
  background: #f1f5f9;
  color: var(--text-secondary, #666666);
  font-size: 11px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  width: auto;
  white-space: nowrap;
  transition: background 0.2s;
}

.quick-question-btn:hover {
  background: #e2e8f0;
}
</style>

<div class="ai-chat-widget" id="aiChatWidget">
  <button class="ai-chat-toggle" id="aiChatToggle" title="智能问答">🤖</button>
  <div class="ai-chat-window" id="aiChatWindow">
    <div class="ai-chat-header">
      <div class="ai-chat-header-left">
        <span class="ai-chat-avatar">🤖</span>
        <div>
          <p class="ai-chat-title">智能问答助手</p>
        </div>
      </div>
      <div class="ai-chat-header-actions">
        <button class="ai-chat-header-btn" id="aiChatClear" title="清空聊天记录">🗑️</button>
        <button class="ai-chat-header-btn" id="aiChatConfig" title="配置">⚙️</button>
        <button class="ai-chat-header-btn" id="aiChatClose" title="关闭">✕</button>
      </div>
    </div>
    <div class="ai-chat-status" id="aiChatStatus">⏳ 初始化...</div>
    <div class="ai-chat-config" id="aiChatConfigPanel">
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">Ollama Base URL</label>
        <input type="text" class="ai-chat-config-input" id="ollamaBaseUrlInput" placeholder="http://localhost:11434/v1" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">Ollama Embedding Model</label>
        <input type="text" class="ai-chat-config-input" id="ollamaEmbeddingModelInput" placeholder="bge-m3:latest" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM Base URL</label>
        <input type="text" class="ai-chat-config-input" id="apiBaseUrlInput" placeholder="https://api.openai.com/v1" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM API Key</label>
        <input type="password" class="ai-chat-config-input" id="apiKeyInput" placeholder="sk-..." />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM Chat Model</label>
        <input type="text" class="ai-chat-config-input" id="chatModelInput" placeholder="gpt-4o-mini" />
      </div>
      <button class="ai-chat-save-btn" id="saveApiConfig">保存配置</button>
      <div class="ai-chat-config-group" style="margin-top: 12px;">
        <label class="ai-chat-config-label">日志级别</label>
        <select class="ai-chat-config-input" id="logLevelInput" style="cursor: pointer;">
          <option value="debug">Debug (最详细)</option>
          <option value="info" selected>Info (推荐)</option>
          <option value="warn">Warn</option>
          <option value="error">Error</option>
        </select>
      </div>
      <button class="ai-chat-save-btn" id="exportLogsBtn" style="margin-top: 6px;">导出日志</button>
      <p class="ai-chat-config-note">💡 配置和聊天记录仅保存在本地浏览器中</p>
    </div>
    <div class="ai-chat-messages" id="aiChatMessages"></div>
    <div class="ai-chat-input-area">
      <div class="ai-chat-input-wrapper">
        <textarea class="ai-chat-input" id="aiChatInput" placeholder="输入你的问题..." rows="1" disabled></textarea>
        <button class="ai-chat-send-btn" id="aiChatSend" disabled>发送</button>
      </div>
      <div class="quick-questions" id="quickQuestions">
        <button class="quick-question-btn" data-question="作为人工智能的技术专家，将本文档转化为易于理解的摘要。">总结本文档的核心内容</button>
        <button class="quick-question-btn" data-question="OpenClaw 的架构设计">OpenClaw 的架构设计</button>
        <button class="quick-question-btn" data-question="智能体的工作原理">智能体的工作流程</button>
      </div>
    </div>
  </div>
</div>

<script src="../scripts/aichat.ts"></script>
