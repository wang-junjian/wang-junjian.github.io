---
import { getCollection } from 'astro:content';
import TypePage from '../../components/TypePage.astro';
import {
  TYPE_PAGE_CONFIG,
  getTypePageData,
  getTypeSidebarData,
  getTypeStaticPaths,
  parseTypePageParam,
  typePageNeedsKatex,
} from '../../utils/typePages';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  return getTypeStaticPaths(allPosts, 'note');
}

const allPosts = await getCollection('posts');
const page = parseTypePageParam(Astro.params.path);
const config = TYPE_PAGE_CONFIG.note;
const { typePosts, pageResult, dayGroups, sortedDays } = getTypePageData(allPosts, 'note', page);
const { recentContent, recentTags } = getTypeSidebarData(typePosts);
const needsKatex = typePageNeedsKatex(pageResult.items);
---

<TypePage
  title={config.title}
  description={config.description}
  pageTitle={config.pageTitle}
  countLabel={config.countLabel(typePosts.length)}
  emptyMessage={config.emptyMessage}
  type={config.typeFilter}
  dayGroups={dayGroups}
  sortedDays={sortedDays}
  currentPage={pageResult.currentPage}
  totalPages={pageResult.totalPages}
  baseUrl="/notes"
  recentContent={recentContent}
  recentTags={recentTags}
  totalPosts={typePosts.length}
  needsKatex={needsKatex}
/>
