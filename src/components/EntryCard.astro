---
import { formatDate, renderPreview, generateExcerpt } from '../utils/posts';
import sharp from 'sharp';
import path from 'node:path';

interface Props {
  id: string;
  title: string;
  date: Date;
  excerpt?: string;
  body?: string;
  tags?: string[];
  image?: string;
  readingTime?: number;
  wordCount?: number;
  showDate?: boolean;
  index?: number;
}

async function addImageDimensions(html: string): Promise<string> {
  const imgRegex = /<img\s+([^>]*?)src="([^"]+)"([^>]*?)>/gi;
  const matches = Array.from(html.matchAll(imgRegex));

  for (const match of matches) {
    const src = match[2];
    if (!src.startsWith('/')) continue;
    if (match[0].includes('width=') || match[0].includes('height=')) continue;

    try {
      const imagePath = path.join(process.cwd(), 'public', src);
      const metadata = await sharp(imagePath).metadata();
      if (metadata.width && metadata.height) {
        const newTag = `<img ${match[1]}src="${src}"${match[3]} width="${metadata.width}" height="${metadata.height}">`;
        html = html.replace(match[0], newTag);
      }
    } catch {
      // Ignore failed reads
    }
  }

  return html;
}

const {
  id,
  title,
  date,
  excerpt,
  body,
  tags = [],
  image,
  readingTime,
  wordCount,
  showDate = true,
  index = 0,
} = Astro.props;

const href = `/posts/${id}/`;
let previewHtml = renderPreview(body, 600);
previewHtml = await addImageDimensions(previewHtml);
const searchExcerpt = generateExcerpt(excerpt || body, 120).toLowerCase();

let imageWidth: number | undefined;
let imageHeight: number | undefined;

if (image) {
  try {
    const imagePath = image.startsWith('/')
      ? path.join(process.cwd(), 'public', image)
      : image;
    const metadata = await sharp(imagePath).metadata();
    imageWidth = metadata.width ?? undefined;
    imageHeight = metadata.height ?? undefined;
  } catch (err) {
    console.warn(`Failed to read image dimensions for ${image}:`, err);
  }
}
---

<article
  class="post-item entry-card"
  style={`animation-delay: ${((index % 6) * 0.1).toFixed(1)}s;`}
  data-title={title.toLowerCase()}
  data-excerpt={searchExcerpt}
  data-id={id}
>
  <h3 class="entry-title">
    <a href={href}>{title}</a>
  </h3>

  {image && (
    <a href={href} class="entry-image">
      <img src={image} alt={title} width={imageWidth} height={imageHeight} loading="lazy" decoding="async" />
    </a>
  )}

  {previewHtml && <div class="entry-excerpt" set:html={previewHtml} />}

  <div class="entry-meta">
    {showDate && (
      <time datetime={date.toISOString()}>
        {formatDate(date)}
      </time>
    )}

    {typeof readingTime === 'number' && readingTime > 0 && (
      <span class="meta-separator" aria-hidden="true">·</span>
      <span>{readingTime} 分钟</span>
    )}

    {typeof wordCount === 'number' && wordCount > 0 && (
      <span class="meta-separator" aria-hidden="true">·</span>
      <span>{wordCount.toLocaleString('zh-CN')} 字</span>
    )}
  </div>

  {tags.length > 0 && (
    <div class="entry-tags">
      {tags.map((tag) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`} class="entry-tag">{tag}</a>
      ))}
    </div>
  )}
</article>
