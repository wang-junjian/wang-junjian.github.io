---
interface Props {
  href: string;
  title: string;
  date?: string;
  excerpt?: string;
  linkText?: string;
  showDate?: boolean;
  showLink?: boolean;
  index?: number;
  compact?: boolean;
  dataTurbo?: boolean | 'false';
}

const { href, title, date, excerpt, linkText = '阅读', showDate = true, showLink = true, index = 0, compact = false, dataTurbo = true } = Astro.props;
---

<article
  class:list={[
    'post-item animate-fade-in-up flex flex-col border-b border-[var(--border)]',
    compact ? 'gap-2 pb-4' : 'gap-4 pb-8',
  ]}
  style={`animation-delay: ${(index % 6) * 0.1}s;`}
  data-title={title.toLowerCase()}
  data-excerpt={(excerpt || '').toLowerCase()}
>
  {showDate && date && (
    <time class="text-xs uppercase tracking-[0.08em] text-[var(--text-secondary)] font-medium">
      {date}
    </time>
  )}
  <h3 class:list={['font-serif-display font-semibold leading-[1.3] tracking-[-0.02em]', compact ? 'text-xl' : 'text-2xl']}>
    <a href={href} class="text-[var(--text-primary)] no-underline transition-colors duration-200 hover:text-[var(--accent)]" data-turbo={dataTurbo === false || dataTurbo === 'false' ? 'false' : undefined}>
      {title}
    </a>
  </h3>
  {excerpt && (
    <p class:list={['text-[var(--text-secondary)] leading-relaxed', compact ? 'text-sm' : 'text-[0.95rem]']}>
      {excerpt}
    </p>
  )}
  {showLink && (
    <a href={href} class="inline-flex items-center gap-2 text-[var(--text-primary)] no-underline text-sm font-medium mt-auto w-fit group" data-turbo={dataTurbo === false || dataTurbo === 'false' ? 'false' : undefined}>
      {linkText}
      <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
    </a>
  )}
</article>
