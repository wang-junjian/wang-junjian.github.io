---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';
import { formatDate } from '../utils/posts';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="related-posts max-w-content mx-auto px-8 pb-16">
    <h2 class="font-serif-display text-2xl font-semibold tracking-[-0.02em] mb-12">
      相关文章
    </h2>
    <div class="grid grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-12">
      {posts.map((post, index) => (
        <PostCard
          href={`/posts/${post.id}`}
          title={post.data.title || post.id}
          date={formatDate(post.data.date)}
          excerpt={post.data.excerpt}
          index={index}
        />
      ))}
    </div>
  </section>
)}
