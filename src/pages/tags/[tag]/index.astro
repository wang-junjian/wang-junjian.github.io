---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTagStaticPaths, getTagPageData } from '../../../utils/tagPages';
import { SITE_TITLE } from '../../../consts';
import TagPageHeader from '../../../components/TagPageHeader.astro';
import DayGroup from '../../../components/DayGroup.astro';
import Pagination from '../../../components/Pagination.astro';
import TagSidebar from '../../../components/TagSidebar.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return getTagStaticPaths(posts);
}

const { tag, posts, allTagCounts } = Astro.props;
const tagUrl = `/tags/${encodeURIComponent(tag)}`;

const {
  pageResult,
  dayGroups,
  sortedDays,
  recentTags,
  pageNeedsKatex,
} = getTagPageData(tag, posts, allTagCounts, 1);
---

<BaseLayout
  title={`${tag} - 标签 - ${SITE_TITLE}`}
  description={`浏览标签 "${tag}" 下的文章。`}
  canonical={Astro.url.toString()}
  showChat={false}
  needsKatex={pageNeedsKatex}
>
  <TagPageHeader tag={tag} postCount={posts.length} />

  <link rel="stylesheet" href="/styles/prose.css" />
  <div class="max-w-grid mx-auto">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
      <!-- Main Stream -->
      <div class="flex-1 min-w-0">
        <div id="postsContainer" class="stream-container">
          {
            sortedDays.map((dayKey, dayIndex) => {
              const dayPosts = dayGroups.get(dayKey) || [];
              const entryStartIndex = sortedDays
                .slice(0, dayIndex)
                .reduce((acc, key) => acc + (dayGroups.get(key)?.length || 0), 0);
              return (
                <DayGroup
                  date={new Date(dayKey + 'T00:00:00')}
                  posts={dayPosts}
                  startIndex={entryStartIndex}
                />
              );
            })
          }
        </div>

        <Pagination
          currentPage={pageResult.currentPage}
          totalPages={pageResult.totalPages}
          baseUrl={tagUrl}
        />
      </div>

      <!-- Sidebar -->
      <TagSidebar recentTags={recentTags} />
    </div>
  </div>
  <script>
    import { enhancePostContent } from '../../../scripts/post-scripts';

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', enhancePostContent);
    } else {
      enhancePostContent();
    }
    document.addEventListener('turbo:load', enhancePostContent);
  </script>
</BaseLayout>
