---

<button
  id="scrollToTop"
  class="scroll-to-top fixed bottom-8 right-8 z-40 p-3 rounded-full border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-secondary)] shadow-lg opacity-0 translate-y-4 pointer-events-none transition-all duration-300 hover:text-[var(--text-primary)] hover:border-[var(--text-primary)]"
  aria-label="返回顶部"
  title="返回顶部"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="m18 15-6-6-6 6"/>
  </svg>
</button>

<script is:inline>
  (function() {
    function initScrollToTop() {
      const btn = document.getElementById('scrollToTop');
      if (!btn) return;

      // Remove any existing listener to avoid duplicates on Turbo navigation
      if ((btn).__scrollHandler) {
        window.removeEventListener('scroll', (btn).__scrollHandler);
      }

      function onScroll() {
        const isVisible = window.scrollY > 400;
        btn.classList.toggle('opacity-0', !isVisible);
        btn.classList.toggle('translate-y-4', !isVisible);
        btn.classList.toggle('pointer-events-none', !isVisible);
      }

      (btn).__scrollHandler = onScroll;
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'auto' });
      });
    }

    initScrollToTop();
    document.addEventListener('turbo:load', initScrollToTop);
  })();
</script>
