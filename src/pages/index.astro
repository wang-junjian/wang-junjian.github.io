---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import PostCard from '../components/PostCard.astro';

const posts = await getCollection('posts');

// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

// Prepare posts data for random picker
const postsData = sortedPosts.map(post => ({
  id: post.id,
  title: post.data.title || post.id
}));
---

<BaseLayout title={`${SITE_TITLE} - ${SITE_DESCRIPTION}`}>
  <!-- Header with Search -->
  <section class="pt-20 pb-12 px-8 bg-white border-b border-[var(--border)]">
    <div class="max-w-[800px] mx-auto text-center animate-fade-in-up">
      <!-- Search Box with Random Button -->
      <div class="relative max-w-[550px] mx-auto flex gap-4 items-center">
        <!-- Random Post Button -->
        <button
          id="randomPostBtn"
          class="group relative flex-shrink-0 w-16 h-16 flex items-center justify-center bg-[var(--bg-primary)] border-2 border-[var(--border)] hover:border-[var(--accent)] transition-all duration-400 ease hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 active:shadow-none"
          title="随机阅读一篇文章"
        >
          <span class="text-2xl transition-all duration-500 group-hover:rotate-180 group-hover:scale-110">🎲</span>
          <span class="absolute -bottom-9 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-all duration-400 text-xs text-[var(--text-secondary)] whitespace-nowrap font-sans tracking-wide">
            随机一篇
          </span>
        </button>

        <!-- Search Input -->
        <div class="relative flex-1">
          <input
            type="text"
            id="searchInput"
            placeholder="搜索文章..."
            class="w-full py-4.5 pl-14 pr-6 text-base border-2 border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] outline-none transition-all duration-200 ease font-sans focus:border-[var(--text-primary)] focus:bg-white"
          />
          <span class="absolute left-5 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] text-xl pointer-events-none">
            🔍
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16 px-8">
    <div class="max-w-grid mx-auto">
      <div class="flex items-baseline justify-between mb-12">
        <h2 class="font-serif-display text-2xl font-semibold tracking-[-0.02em]">
          全部文章
        </h2>
        <span id="postCount" class="text-[var(--text-secondary)] text-sm tabular-nums">
          {sortedPosts.length} 篇
        </span>
      </div>

      <div id="postsContainer" class="grid grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-12">
        {sortedPosts.map((post, index) => (
          <PostCard
            href={`/posts/${post.id}`}
            title={post.data.title || post.id}
            date={formatDate(post.data.date)}
            excerpt={post.data.excerpt}
            index={index}
          />
        ))}
      </div>

      <!-- No Results Message -->
      <div id="noResults" class="hidden text-center py-16 px-8">
        <p class="font-serif-display text-2xl text-[var(--text-secondary)]">
          没有找到匹配的文章
        </p>
      </div>
    </div>
  </section>

  <script is:inline set:html={`const postsData = ${JSON.stringify(postsData)};`}></script>
  <script src="../scripts/search.ts"></script>
</BaseLayout>
