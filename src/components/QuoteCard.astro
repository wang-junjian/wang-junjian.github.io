---
import { marked } from 'marked';
import { formatTime, normalizeTags, renderCardExcerpt } from '../utils/posts';

interface Props {
  id: string;
  body?: string;
  author?: string;
  title?: string;
  linkUrl?: string;
  context?: string;
  date: Date;
  tags?: string[] | string | null;
  showDate?: boolean;
  index?: number;
}

const {
  id,
  body,
  author,
  title,
  linkUrl,
  context,
  date,
  tags,
  showDate = true,
  index = 0,
} = Astro.props;

const quoteHtml = body ? renderCardExcerpt(body) : '';
const href = `/posts/${id}/`;
const tagList = normalizeTags(tags);
---

<article
  class="post-item quote-card"
  style={`animation-delay: ${((index % 6) * 0.1).toFixed(1)}s;`}
  data-id={id}
>
  <div class="link-header">
    <a href="/quotes/" class="type-badge type-badge-quote">引用</a>

    <h3 class="link-title">
      {linkUrl ? (
        <>
          <a href={href}>{title || linkUrl}</a>
          <a
            href={linkUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-external-link"
            aria-label="访问外部链接"
          >
            <span class="link-external-icon" aria-hidden="true">🔗</span>
          </a>
        </>
      ) : (
        <a href={href}>{title || '引用'}</a>
      )}
    </h3>
  </div>

  <div class="quote-body card-body" set:html={quoteHtml} />

  <figcaption class="quote-attribution">
    <span aria-hidden="true">—</span>
    {author ? <span>{author}</span> : <span>未知作者</span>}
    {context && <span>, {context}</span>}
  </figcaption>

  <div class="entry-meta">
    {showDate && (
      <a href={href} class="post-time-link">
        <time datetime={date.toISOString()}>
          {formatTime(date)}
        </time>
      </a>
    )}

    {tagList.length > 0 && (
      <>
        <span class="meta-separator" aria-hidden="true">·</span>
        <div class="entry-tags">
          {tagList.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}/`} class="entry-tag">{tag}</a>
          ))}
        </div>
      </>
    )}
  </div>
</article>
