---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getAllCategories } from '../utils/posts';
import { SITE_TITLE } from '../consts';
import PageHeader from '../components/PageHeader.astro';
import TaxonomyPage from '../components/TaxonomyPage.astro';

const posts = await getCollection('posts');
const categories = getAllCategories(posts);
const sortedCategories = Array.from(categories.entries()).sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title={`分类 - ${SITE_TITLE}`}>
  <PageHeader
    title="分类"
    subtitle={`共 ${categories.size} 个分类，${posts.length} 篇文章`}
  />
  <TaxonomyPage
    taxonomyType="category"
    items={sortedCategories}
    totalPosts={posts.length}
    labelSingular="分类"
    labelPlural="分类"
  />
</BaseLayout>
