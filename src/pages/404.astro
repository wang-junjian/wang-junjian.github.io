---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
---

<BaseLayout
  title={`页面未找到 - ${SITE_TITLE}`}
  description="抱歉，你访问的页面不存在。"
  canonical={Astro.url.toString().replace(/\/404\.html$/, '/404')}
>
  <section class="pt-32 pb-20 px-8 text-center">
    <div class="max-w-content mx-auto animate-fade-in-up">
      <h1 class="font-serif-display text-[6rem] font-semibold leading-none tracking-[-0.05em] text-[var(--text-primary)] mb-6">
        404
      </h1>
      <p class="text-2xl text-[var(--text-secondary)] mb-4">
        页面未找到
      </p>
      <p class="text-[var(--text-secondary)] mb-10">
        抱歉，你访问的页面可能已被移动、删除或暂时不可用。
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] rounded-md text-[var(--text-primary)] hover:border-[var(--text-primary)] transition-colors duration-200 no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        返回首页
      </a>
    </div>
  </section>
</BaseLayout>
