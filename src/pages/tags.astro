---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getAllTags } from '../utils/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import TaxonomyPage from '../components/TaxonomyPage.astro';

const posts = await getCollection('posts');
const tags = getAllTags(posts);
const sortedTags = Array.from(tags.entries()).sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout
  title={`标签 - ${SITE_TITLE}`}
  description={`浏览 ${SITE_TITLE} 的文章标签。${SITE_DESCRIPTION}`}
  canonical={Astro.url.toString()}
>
  <TaxonomyPage
    taxonomyType="tag"
    items={sortedTags}
    totalPosts={posts.length}
    labelSingular="标签"
    labelPlural="标签"
  />
</BaseLayout>
