---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import Pagination from './Pagination.astro';
import StreamSidebar from './StreamSidebar.astro';
import StreamTabs from './StreamTabs.astro';
import StreamSearchBar from './StreamSearchBar.astro';
import StreamContent from './StreamContent.astro';

interface Props {
  title: string;
  description: string;
  pageTitle: string;
  countLabel: string;
  emptyMessage: string;
  type: string;
  dayGroups: Map<string, CollectionEntry<'posts'>[]>;
  sortedDays: string[];
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  recentContent: Array<{ id: string; title: string; date: Date | string }>;
  recentTags: Array<[string, number]>;
  totalPosts: number;
  needsKatex?: boolean;
}

const {
  title,
  description,
  pageTitle,
  countLabel,
  emptyMessage,
  type,
  dayGroups,
  sortedDays,
  currentPage,
  totalPages,
  baseUrl,
  recentContent,
  recentTags,
  totalPosts,
  needsKatex = false,
} = Astro.props;

const pageTitleText = currentPage > 1 ? `${pageTitle} - 第 ${currentPage} 页` : pageTitle;
---

<BaseLayout
  title={`${pageTitleText} - ${SITE_TITLE}`}
  description={description}
  canonical={Astro.url.toString()}
  showChat={false}
  needsKatex={needsKatex}
>
  <link rel="stylesheet" href="/styles/prose.css" />
  <section class="pt-10 pb-6 px-8">
    <div class="max-w-grid mx-auto">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        <!-- Main Stream -->
        <div class="flex-1 min-w-0">
          <StreamTabs currentType={type} />
          <StreamSearchBar placeholder={`在${pageTitle}中搜索...`} />

          <StreamContent
            dayGroups={dayGroups}
            sortedDays={sortedDays}
            emptyMessage={emptyMessage}
            type={type}
            totalPosts={totalPosts}
          />

          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            baseUrl={baseUrl}
          />
        </div>

        <!-- Sidebar -->
        <StreamSidebar
          totalPosts={totalPosts}
          recentTags={recentTags}
          recentContent={recentContent}
          randomContent={[]}
          randomTools={[]}
        />
      </div>
    </div>
  </section>

  <script src="../scripts/post-scripts.ts"></script>
  <script src="../scripts/search.ts"></script>
</BaseLayout>
