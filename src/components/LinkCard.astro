---
import { formatTime, normalizeTags, renderCardExcerpt } from '../utils/posts';

interface Props {
  id: string;
  title?: string;
  linkUrl?: string;
  body?: string;
  date: Date;
  tags?: string[] | string | null;
  showDate?: boolean;
  index?: number;
}

const {
  id,
  title,
  linkUrl,
  body,
  date,
  tags,
  showDate = true,
  index = 0,
} = Astro.props;

const bodyHtml = body ? renderCardExcerpt(body) : '';
const href = `/posts/${id}/`;
const tagList = normalizeTags(tags);
---

<article
  class="post-item link-card"
  style={`animation-delay: ${((index % 6) * 0.1).toFixed(1)}s;`}
  data-id={id}
>
  <div class="link-header">
    <a href="/links/" class="type-badge type-badge-link">链接</a>

    <h3 class="link-title">
      {linkUrl ? (
        <>
          <a href={href}>{title || linkUrl}</a>
          <a
            href={linkUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="link-external-link"
            aria-label="访问外部链接"
          >
            <span class="link-external-icon" aria-hidden="true">🔗</span>
          </a>
        </>
      ) : (
        <a href={href}>{title || '链接'}</a>
      )}
    </h3>
  </div>

  {bodyHtml && <div class="link-body card-body" set:html={bodyHtml} />}

  <div class="entry-meta">
    {showDate && (
      <a href={href} class="post-time-link">
        <time datetime={date.toISOString()}>{formatTime(date)}</time>
      </a>
    )}

    {tagList.length > 0 && (
      <>
        <span class="meta-separator" aria-hidden="true">·</span>
        <div class="entry-tags">
          {tagList.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}/`} class="entry-tag">
              {tag}
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</article>
