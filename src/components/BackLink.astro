---
interface Props {
  href?: string;
  label?: string;
}

const { href = '/', label = '返回首页' } = Astro.props;
---

<a href={href} class="inline-flex items-center gap-2 text-[var(--text-secondary)] no-underline text-sm mb-8 transition-colors duration-200 hover:text-[var(--accent)]">
  <span>←</span>
  {label}
</a>
