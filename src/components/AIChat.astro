<style is:global>
.ai-chat-widget {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 9999;
  font-family: inherit;
}

.ai-chat-toggle {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.ai-chat-toggle:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
}

.ai-chat-window {
  position: absolute;
  bottom: 76px;
  right: 0;
  width: 460px;
  height: 750px;
  background: var(--white, #ffffff);
  border-radius: 16px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  display: none;
  flex-direction: column;
}

.ai-chat-window.open {
  display: flex;
}

.ai-chat-header {
  padding: 12px 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.ai-chat-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.ai-chat-avatar {
  font-size: 22px;
}

.ai-chat-title {
  font-size: 14px;
  font-weight: 600;
  margin: 0;
}

.ai-chat-subtitle {
  font-size: 11px;
  opacity: 0.8;
  margin: 0;
}

.ai-chat-header-actions {
  display: flex;
  gap: 6px;
}

.ai-chat-header-btn {
  background: none;
  border: none;
  color: white;
  font-size: 16px;
  cursor: pointer;
  padding: 4px;
  opacity: 0.8;
  transition: opacity 0.2s;
}

.ai-chat-header-btn:hover {
  opacity: 1;
}

.ai-chat-status {
  padding: 6px 12px;
  font-size: 11px;
  background: #fef3c7;
  color: #92400e;
  flex-shrink: 0;
}

.ai-chat-status.success {
  background: #d1fae5;
  color: #065f46;
}

.ai-chat-config {
  padding: 12px;
  background: #f8fafc;
  border-bottom: 1px solid var(--border, #e0ddd8);
  flex-shrink: 0;
  overflow-y: auto;
  max-height: 50vh;
  display: none;
}

.ai-chat-config.open {
  display: block;
}

.ai-chat-config-group {
  margin-bottom: 10px;
}

.ai-chat-config-label {
  display: block;
  font-size: 12px;
  color: var(--text-secondary, #666666);
  margin-bottom: 3px;
}

.ai-chat-config-input {
  width: 100%;
  padding: 7px 10px;
  border: 1px solid var(--border, #e0ddd8);
  border-radius: 6px;
  font-size: 13px;
  outline: none;
  background: var(--white, #ffffff);
  color: var(--text-primary, #1a1a1a);
  box-sizing: border-box;
}

.ai-chat-config-input:focus {
  border-color: #667eea;
}

.ai-chat-save-btn {
  width: 100%;
  padding: 8px;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  margin-top: 6px;
}

.ai-chat-config-note {
  font-size: 10px;
  color: var(--text-secondary, #666666);
  margin-top: 6px;
}

.ai-chat-messages {
  flex: 1;
  padding: 12px;
  overflow-y: auto;
  background: #fafafa;
}

.ai-chat-message {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
  align-items: flex-start;
}

.ai-chat-message-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

.ai-chat-message.user .ai-chat-message-avatar {
  background: #f0e2e7;
}

.ai-chat-message.assistant .ai-chat-message-avatar {
  background: #667eea;
}

.ai-chat-message-content {
  flex: 1;
  padding: 10px 12px;
  border-radius: 10px;
  line-height: 1.5;
  font-size: 13px;
  word-wrap: break-word;
}

.ai-chat-message.user .ai-chat-message-content {
  background: #e2e8f0;
}

.ai-chat-message.assistant .ai-chat-message-content {
  background: var(--white, #ffffff);
  border: 1px solid var(--border, #e0ddd8);
}

.ai-chat-message-content h1,
.ai-chat-message-content h2,
.ai-chat-message-content h3,
.ai-chat-message-content h4 {
  margin-top: 0.8em;
  margin-bottom: 0.4em;
  font-weight: 600;
  line-height: 1.25;
}

.ai-chat-message-content h1 { font-size: 1.4em; }
.ai-chat-message-content h2 { font-size: 1.2em; }
.ai-chat-message-content h3 { font-size: 1.1em; }
.ai-chat-message-content h4 { font-size: 1em; }

.ai-chat-message-content p {
  margin-top: 0.4em;
  margin-bottom: 0.4em;
}

.ai-chat-message-content a {
  color: #667eea;
  text-decoration: underline;
}

.ai-chat-message-content strong {
  font-weight: 600;
}

.ai-chat-message-content em {
  font-style: italic;
}

.ai-chat-message-content ul,
.ai-chat-message-content ol {
  margin-top: 0.4em;
  margin-bottom: 0.4em;
  padding-left: 1.4em;
}

.ai-chat-message-content li {
  margin-top: 0.2em;
  margin-bottom: 0.2em;
}

.ai-chat-message-content code {
  background: #f1f5f9;
  padding: 0.1em 0.3em;
  border-radius: 3px;
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  font-size: 0.85em;
}

.ai-chat-message-content pre {
  background: #1e293b;
  color: #e2e8f0;
  padding: 0.8em;
  border-radius: 6px;
  overflow-x: auto;
  margin-top: 0.6em;
  margin-bottom: 0.6em;
}

.ai-chat-message-content pre code {
  background: none;
  padding: 0;
  color: inherit;
  font-size: 0.85em;
}

.ai-chat-input-area {
  padding: 12px;
  border-top: 1px solid var(--border, #e0ddd8);
  background: var(--white, #ffffff);
  flex-shrink: 0;
}

.ai-chat-input-wrapper {
  display: flex;
  gap: 10px;
  align-items: flex-end;
}

.ai-chat-input {
  flex: 1;
  padding: 10px 12px;
  border: 1px solid var(--border, #e0ddd8);
  border-radius: 10px;
  font-size: 13px;
  resize: none;
  outline: none;
  font-family: inherit;
  line-height: 1.4;
  max-height: 100px;
}

.ai-chat-input:focus {
  border-color: #667eea;
}

.ai-chat-input:disabled {
  background: #f1f5f9;
  cursor: not-allowed;
}

.ai-chat-send-btn {
  padding: 10px 16px;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.2s;
  flex-shrink: 0;
}

.ai-chat-send-btn:hover:not(:disabled) {
  background: #5a6fd6;
}

.ai-chat-send-btn:disabled {
  background: #cbd5e1;
  cursor: not-allowed;
}

.ai-chat-loading {
  display: inline-flex;
  gap: 3px;
}

.ai-chat-loading span {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--text-secondary, #666666);
  animation: ai-chat-bounce 1.4s infinite ease-in-out both;
}

.ai-chat-loading span:nth-child(1) {
  animation-delay: -0.32s;
}

.ai-chat-loading span:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes ai-chat-bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.quick-questions {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 10px;
}

.quick-question-btn {
  padding: 5px 10px;
  background: #f1f5f9;
  color: var(--text-secondary, #666666);
  font-size: 11px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  width: auto;
  white-space: nowrap;
  transition: background 0.2s;
}

.quick-question-btn:hover {
  background: #e2e8f0;
}
</style>

<div class="ai-chat-widget" id="aiChatWidget">
  <button class="ai-chat-toggle" id="aiChatToggle" title="智能问答">🤖</button>
  <div class="ai-chat-window" id="aiChatWindow">
    <div class="ai-chat-header">
      <div class="ai-chat-header-left">
        <span class="ai-chat-avatar">🤖</span>
        <div>
          <p class="ai-chat-title">智能问答助手</p>
          <p class="ai-chat-subtitle">Ollama + AI 问答</p>
        </div>
      </div>
      <div class="ai-chat-header-actions">
        <button class="ai-chat-header-btn" id="aiChatClear" title="清空聊天记录">🗑️</button>
        <button class="ai-chat-header-btn" id="aiChatConfig" title="配置">⚙️</button>
        <button class="ai-chat-header-btn" id="aiChatClose" title="关闭">✕</button>
      </div>
    </div>
    <div class="ai-chat-status" id="aiChatStatus">⏳ 初始化...</div>
    <div class="ai-chat-config" id="aiChatConfigPanel">
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">Ollama Base URL</label>
        <input type="text" class="ai-chat-config-input" id="ollamaBaseUrlInput" placeholder="http://localhost:11434/v1" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">Ollama Embedding Model</label>
        <input type="text" class="ai-chat-config-input" id="ollamaEmbeddingModelInput" placeholder="bge-m3:latest" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM Base URL</label>
        <input type="text" class="ai-chat-config-input" id="apiBaseUrlInput" placeholder="https://api.openai.com/v1" />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM API Key</label>
        <input type="password" class="ai-chat-config-input" id="apiKeyInput" placeholder="sk-..." />
      </div>
      <div class="ai-chat-config-group">
        <label class="ai-chat-config-label">LLM Chat Model</label>
        <input type="text" class="ai-chat-config-input" id="chatModelInput" placeholder="gpt-4o-mini" />
      </div>
      <button class="ai-chat-save-btn" id="saveApiConfig">保存配置</button>
      <p class="ai-chat-config-note">💡 配置和聊天记录仅保存在本地浏览器中</p>
    </div>
    <div class="ai-chat-messages" id="aiChatMessages"></div>
    <div class="ai-chat-input-area">
      <div class="ai-chat-input-wrapper">
        <textarea class="ai-chat-input" id="aiChatInput" placeholder="输入你的问题..." rows="1" disabled></textarea>
        <button class="ai-chat-send-btn" id="aiChatSend" disabled>发送</button>
      </div>
      <div class="quick-questions" id="quickQuestions">
        <button class="quick-question-btn" data-question="这个博客讲了什么？">这个博客讲了什么？</button>
        <button class="quick-question-btn" data-question="有哪些技术文章？">有哪些技术文章？</button>
        <button class="quick-question-btn" data-question="推荐几篇入门文章">推荐几篇入门文章</button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const STORAGE_KEY_CONFIG = 'ai_chat_config';
  const STORAGE_KEY_MESSAGES = 'ai_chat_messages';
  const STORAGE_KEY_WINDOW_OPEN = 'ai_chat_window_open';

  let apiConfig = {
    ollamaBaseUrl: 'http://localhost:11434/v1',
    ollamaEmbeddingModel: 'bge-m3:latest',
    baseUrl: 'https://api.longcat.chat/openai/',
    apiKey: '',
    chatModel: 'LongCat-Flash-Lite',
  };
  let messages = [];
  let embeddingsLoaded = false;
  let isWindowOpen = false;

  const toggleBtn = document.getElementById('aiChatToggle');
  const chatWindow = document.getElementById('aiChatWindow');
  const closeBtn = document.getElementById('aiChatClose');
  const configBtn = document.getElementById('aiChatConfig');
  const clearBtn = document.getElementById('aiChatClear');
  const configPanel = document.getElementById('aiChatConfigPanel');
  const statusEl = document.getElementById('aiChatStatus');
  const messagesEl = document.getElementById('aiChatMessages');
  const inputEl = document.getElementById('aiChatInput');
  const sendBtn = document.getElementById('aiChatSend');
  const quickQuestionsEl = document.getElementById('quickQuestions');
  const ollamaBaseUrlInput = document.getElementById('ollamaBaseUrlInput');
  const ollamaEmbeddingModelInput = document.getElementById('ollamaEmbeddingModelInput');
  const apiBaseUrlInput = document.getElementById('apiBaseUrlInput');
  const apiKeyInput = document.getElementById('apiKeyInput');
  const chatModelInput = document.getElementById('chatModelInput');
  const saveConfigBtn = document.getElementById('saveApiConfig');

  function updateStatus(text, type = 'warning') {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.className = 'ai-chat-status ' + type;
  }

  function saveConfig() {
    localStorage.setItem(STORAGE_KEY_CONFIG, JSON.stringify(apiConfig));
  }

  function loadConfig() {
    const saved = localStorage.getItem(STORAGE_KEY_CONFIG);
    if (saved) {
      apiConfig = { ...apiConfig, ...JSON.parse(saved) };
    }
    if (ollamaBaseUrlInput) ollamaBaseUrlInput.value = apiConfig.ollamaBaseUrl;
    if (ollamaEmbeddingModelInput) ollamaEmbeddingModelInput.value = apiConfig.ollamaEmbeddingModel;
    if (apiBaseUrlInput) apiBaseUrlInput.value = apiConfig.baseUrl;
    if (apiKeyInput) apiKeyInput.value = apiConfig.apiKey;
    if (chatModelInput) chatModelInput.value = apiConfig.chatModel;
  }

  function saveMessages() {
    localStorage.setItem(STORAGE_KEY_MESSAGES, JSON.stringify(messages));
  }

  function loadMessages() {
    const saved = localStorage.getItem(STORAGE_KEY_MESSAGES);
    if (saved) {
      messages = JSON.parse(saved);
    }
    renderMessages();
  }

  function renderMessages() {
    if (!messagesEl) return;
    if (messages.length === 0) {
      messagesEl.innerHTML = `
        <div style="text-align: center; padding: 30px 16px; color: var(--text-secondary, #666666);">
          <span style="font-size: 40px; display: block; margin-bottom: 12px;">👋</span>
          <p style="margin: 0 0 6px 0; font-size: 13px;">你好！我是智能问答助手</p>
          <p style="margin: 0; font-size: 11px;">配置完成后开始提问</p>
        </div>
      `;
      if (quickQuestionsEl) quickQuestionsEl.style.display = 'flex';
      return;
    }

    if (quickQuestionsEl) quickQuestionsEl.style.display = 'none';
    messagesEl.innerHTML = messages.map(msg => renderMessage(msg)).join('');
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function renderMessage(msg) {
    const avatar = msg.role === 'user' ? '👤' : '🤖';
    let content;

    if (typeof marked !== 'undefined') {
      content = marked.parse(msg.content);
    } else {
      content = msg.content
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/\n/g, '<br>');
    }

    return `
      <div class="ai-chat-message ${msg.role}">
        <div class="ai-chat-message-avatar">${avatar}</div>
        <div class="ai-chat-message-content">${content}</div>
      </div>
    `;
  }

  function addLoadingMessage(text = '思考中...') {
    if (!messagesEl) return;
    const div = document.createElement('div');
    div.id = 'aiChatLoading';
    div.className = 'ai-chat-message assistant';
    div.innerHTML = `
      <div class="ai-chat-message-avatar">🤖</div>
      <div class="ai-chat-message-content">
        <span style="color: var(--text-secondary, #666666);">${text}</span>
        <div class="ai-chat-loading">
          <span></span><span></span><span></span>
        </div>
      </div>
    `;
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeLoadingMessage() {
    const loading = document.getElementById('aiChatLoading');
    if (loading) loading.remove();
  }

  function checkReadyState() {
    if (embeddingsLoaded && apiConfig.apiKey) {
      if (inputEl) inputEl.disabled = false;
      if (sendBtn) sendBtn.disabled = false;
      if (configPanel) configPanel.classList.remove('open');
      updateStatus('✅ 就绪 - Ollama 向量搜索 + AI 问答', 'success');
    } else if (embeddingsLoaded) {
      if (configPanel) configPanel.classList.add('open');
      updateStatus('⚙️ 请配置 API Key', 'warning');
    }
  }

  async function loadEmbeddings() {
    try {
      updateStatus('📚 加载向量索引...', 'info');
      const response = await fetch('/embeddings.json');
      if (!response.ok) {
        throw new Error('未找到向量索引，请先运行 npm run embed');
      }
      await response.json();
      embeddingsLoaded = true;
      checkReadyState();
    } catch (error) {
      updateStatus(`❌ 加载失败: ${error.message}`, 'error');
      console.error('Failed to load embeddings:', error);
    }
  }

  function cosineSimilarity(a, b) {
    if (a.length !== b.length) return 0;
    let dotProduct = 0, normA = 0, normB = 0;
    for (let i = 0; i < a.length; i++) {
      dotProduct += a[i] * b[i];
      normA += a[i] * a[i];
      normB += b[i] * b[i];
    }
    return dotProduct / (Math.sqrt(normA) * Math.sqrt(normB));
  }

  async function searchSimilar(queryEmbedding, topK = 5) {
    const response = await fetch('/embeddings.json');
    const data = await response.json();
    const results = data.chunks.map(chunk => ({
      chunk,
      similarity: cosineSimilarity(queryEmbedding, chunk.embedding)
    }));
    results.sort((a, b) => b.similarity - a.similarity);
    return results.slice(0, topK);
  }

  async function createEmbedding(text) {
    const baseUrl = (apiConfig.ollamaBaseUrl || 'http://localhost:11434/v1').replace(/\/$/, '');
    const response = await fetch(`${baseUrl}/embeddings`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: apiConfig.ollamaEmbeddingModel,
        input: text,
      }),
    });
    if (!response.ok) throw new Error(`Ollama embedding failed: ${await response.text()}`);
    const data = await response.json();
    return data.data[0].embedding;
  }

  async function generateAnswer(query, contextChunks) {
    const context = contextChunks
      .map((r, i) => `[${i + 1}] ${r.chunk.title}\n${r.chunk.content}`)
      .join('\n\n');

    const slugMap = new Map();
    for (const r of contextChunks) {
      const slug = r.chunk.slug;
      const title = r.chunk.title;
      const similarity = r.similarity;
      if (!slugMap.has(slug) || similarity > slugMap.get(slug).similarity) {
        slugMap.set(slug, { title, similarity });
      }
    }
    const postTitles = Array.from(slugMap.entries()).map(([slug, info]) => [slug, info.title]);

    const systemPrompt = `你是一个专业的技术助手，专门回答关于这个博客内容的问题。请遵循以下规则：
1. 只使用提供的上下文信息来回答问题，不要编造信息
2. 如果上下文中没有相关信息，请诚实地告诉用户
3. 回答要简洁、准确、有帮助
4. 适当使用中文进行回答
5. 不要在回答中添加文章链接，链接会在最后自动添加`;

    const userPrompt = `用户问题：${query}\n\n相关上下文：\n${context}\n\n请根据以上上下文回答用户的问题。`;
    const baseUrl = (apiConfig.baseUrl || 'https://api.longcat.chat/openai/').replace(/\/$/, '');

    const response = await fetch(`${baseUrl}/chat/completions`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiConfig.apiKey}`,
      },
      body: JSON.stringify({
        model: apiConfig.chatModel,
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: userPrompt },
        ],
        temperature: 0.7,
        max_tokens: 1000,
      }),
    });

    if (!response.ok) throw new Error(`LLM failed: ${await response.text()}`);
    const data = await response.json();
    let answer = data.choices[0].message.content;

    const referencesSection = '\n\n参考文章：\n' + postTitles
      .map(([slug, title]) => `- [${title}](/posts/${slug}.html)`)
      .join('\n');
    if (!answer.includes('参考文章：')) answer += referencesSection;
    return answer;
  }

  async function sendMessage(text) {
    if (!text || !apiConfig.apiKey) return;

    messages.push({ role: 'user', content: text });
    saveMessages();
    renderMessages();
    inputEl.value = '';
    inputEl.style.height = 'auto';

    try {
      addLoadingMessage('正在调用 Ollama 向量化...');
      const queryEmbedding = await createEmbedding(text);

      removeLoadingMessage();
      addLoadingMessage('正在本地搜索相关文章...');
      const similarChunks = await searchSimilar(queryEmbedding);

      removeLoadingMessage();
      addLoadingMessage('正在生成回答...');
      const answer = await generateAnswer(text, similarChunks);

      removeLoadingMessage();
      messages.push({ role: 'assistant', content: answer });
      saveMessages();
      renderMessages();
    } catch (error) {
      removeLoadingMessage();
      messages.push({
        role: 'assistant',
        content: `抱歉，发生了错误：${error.message}。请检查 Ollama 是否运行以及 API 配置。`
      });
      saveMessages();
      renderMessages();
    }
  }

  function autoResize() {
    if (!inputEl) return;
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 100) + 'px';
  }

  function toggleWindow() {
    isWindowOpen = !isWindowOpen;
    if (isWindowOpen) {
      chatWindow.classList.add('open');
      toggleBtn.textContent = '✕';
    } else {
      chatWindow.classList.remove('open');
      toggleBtn.textContent = '🤖';
    }
    localStorage.setItem(STORAGE_KEY_WINDOW_OPEN, JSON.stringify(isWindowOpen));
  }

  function restoreWindowState() {
    const saved = localStorage.getItem(STORAGE_KEY_WINDOW_OPEN);
    if (saved && JSON.parse(saved)) {
      toggleWindow();
    }
  }

  function bindEvents() {
    toggleBtn.addEventListener('click', toggleWindow);
    closeBtn.addEventListener('click', toggleWindow);

    configBtn.addEventListener('click', () => {
      configPanel.classList.toggle('open');
    });

    clearBtn.addEventListener('click', () => {
      if (confirm('确定要清空聊天记录吗？')) {
        messages = [];
        saveMessages();
        renderMessages();
      }
    });

    saveConfigBtn.addEventListener('click', () => {
      apiConfig = {
        ollamaBaseUrl: ollamaBaseUrlInput.value.trim() || 'http://localhost:11434/v1',
        ollamaEmbeddingModel: ollamaEmbeddingModelInput.value.trim() || 'bge-m3:latest',
        baseUrl: apiBaseUrlInput.value.trim() || 'https://api.longcat.chat/openai/',
        apiKey: apiKeyInput.value.trim(),
        chatModel: chatModelInput.value.trim() || 'LongCat-Flash-Lite',
      };
      saveConfig();
      checkReadyState();
    });

    sendBtn.addEventListener('click', () => sendMessage(inputEl.value.trim()));
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage(inputEl.value.trim());
      }
    });
    inputEl.addEventListener('input', autoResize);

    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-question]');
      if (btn && !inputEl.disabled) {
        sendMessage(btn.dataset.question);
      }
    });
  }

  function init() {
    bindEvents();
    loadConfig();
    loadMessages();
    restoreWindowState();
    loadEmbeddings();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
